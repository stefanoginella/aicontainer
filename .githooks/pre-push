#!/usr/bin/env bash
# Block pushing a `vX.Y.Z` release tag unless CHANGELOG.md (at the tagged
# commit) has a matching `## [X.Y.Z]` section. This is the fast local mirror of
# release.yml's "Verify CHANGELOG.md has an entry" gate — convenient, but
# bypassable (`--no-verify`) and per-clone, so CI remains the real enforcement.
#
# Enable once per clone:
#   git config core.hooksPath .githooks
#
# stdin lines: <local ref> <local sha> <remote ref> <remote sha>
set -euo pipefail

status=0
while read -r local_ref local_sha _remote_ref _remote_sha; do
  # Only police version tags.
  case "$local_ref" in
    refs/tags/v[0-9]*) ;;
    *) continue ;;
  esac
  # Tag deletion: local_sha is all zeros — nothing to verify.
  case "$local_sha" in
    *[!0]*) ;;
    *) continue ;;
  esac

  ver="${local_ref#refs/tags/v}"
  ver_re="${ver//./\\.}"
  if ! git show "$local_sha:CHANGELOG.md" 2>/dev/null | grep -qE "^## \[$ver_re\]"; then
    echo "pre-push: refusing to push tag v$ver — CHANGELOG.md has no '## [$ver]' section." >&2
    echo "          Add the release notes for v$ver, re-tag, and retry." >&2
    echo "          (Bypass with 'git push --no-verify'; CI will still block the release.)" >&2
    status=1
  fi
done

exit "$status"
