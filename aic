  final_json="$(mktemp "${TMPDIR:-/tmp}/aic-final.XXXXXX")"
  noenv_json="$(mktemp "${TMPDIR:-/tmp}/aic-noenv.XXXXXX")"
  raw_base_json="$(mktemp "${TMPDIR:-/tmp}/aic-raw-base.XXXXXX")"
  raw_final_json="$(mktemp "${TMPDIR:-/tmp}/aic-raw-final.XXXXXX")"
  findings="$(mktemp "${TMPDIR:-/tmp}/aic-findings.XXXXXX")"

  if ! export_runtime_environment; then
    printf 'MANAGED\t%s\n' 'could not resolve a bind-mountable local Docker socket from the selected context' >> "$findings"
    AIC_DOCKER_SOCKET=/var/run/docker.sock
    export AIC_DOCKER_SOCKET
  elif ! validate_runtime_environment_file; then
    printf 'MANAGED\t%s\n' '.devcontainer/.env does not match this host Docker context; run aic sync or aic initialize' >> "$findings"
  fi
  validate_managed_build_files "$findings"
  if [ -f .devcontainer/Dockerfile ]; then
    expected_compose="$TEMPLATE_DIR/docker-compose.build.yml"
  else
    expected_compose="$TEMPLATE_DIR/docker-compose.pull.yml"
  fi

  if ! docker compose -f .devcontainer/docker-compose.yml config --format json > "$base_json" 2>/dev/null; then
    printf 'MANAGED\t%s\n' 'docker-compose.yml could not be resolved; run docker compose config for details' >> "$findings"
  fi
  if ! docker compose -f "$expected_compose" config --format json > "$expected_json" 2>/dev/null; then
    printf 'MANAGED\tinstalled aic Compose template could not be resolved; reinstall aic\n' >> "$findings"
  fi
  if [ -f .devcontainer/docker-compose.override.yml ]; then
    if ! docker compose -f .devcontainer/docker-compose.yml -f .devcontainer/docker-compose.override.yml config --format json > "$final_json" 2>/dev/null; then
      printf 'MANAGED\tmanaged + override Compose configuration could not be resolved\n' >> "$findings"
    fi
    if ! docker compose -f .devcontainer/docker-compose.yml -f .devcontainer/docker-compose.override.yml \
        config --format json --no-env-resolution > "$noenv_json" 2>/dev/null; then
      printf 'MANAGED\tCompose configuration could not be inspected without env-file resolution\n' >> "$findings"
    fi
    # Resolve a second pair without interpolation only when an override exists.
    # Normal generated projects pay no extra Compose-process cost.
    if ! docker compose -f .devcontainer/docker-compose.yml \
        config --format json --no-env-resolution --no-interpolate > "$raw_base_json" 2>/dev/null; then
      printf 'MANAGED\tmanaged Compose interpolation model could not be inspected\n' >> "$findings"
    fi
    if ! docker compose -f .devcontainer/docker-compose.yml -f .devcontainer/docker-compose.override.yml \
        config --format json --no-env-resolution --no-interpolate > "$raw_final_json" 2>/dev/null; then
      printf 'MANAGED\tmerged Compose interpolation model could not be inspected\n' >> "$findings"
    fi
  else
    cp "$base_json" "$final_json"
    if ! docker compose -f .devcontainer/docker-compose.yml config --format json --no-env-resolution > "$noenv_json" 2>/dev/null; then
      printf 'MANAGED\tCompose configuration could not be inspected without env-file resolution\n' >> "$findings"
    fi
    printf '{}\n' > "$raw_base_json"
    printf '{}\n' > "$raw_final_json"
  fi

  if [ -s "$base_json" ] && [ -s "$expected_json" ] && [ -s "$final_json" ] \
     && [ -s "$noenv_json" ] && [ -s "$raw_base_json" ] && [ -s "$raw_final_json" ]; then
    analyze_resolved_config "$base_json" "$expected_json" "$final_json" "$noenv_json" \
      "$raw_base_json" "$raw_final_json" "$findings"
  fi

  managed="$(grep '^MANAGED' "$findings" 2>/dev/null || true)"
  unsafe="$(grep '^UNSAFE' "$findings" 2>/dev/null || true)"
  volatile="$(grep '^VOLATILE' "$findings" 2>/dev/null || true)"
  docker_unsafe="$(grep '^DOCKER' "$findings" 2>/dev/null || true)"
  docker_mode="$(read_compose_docker_mode)"
  if [ -n "$docker_unsafe" ] && ! docker_consent_matches "$docker_mode"; then
    unsafe="${unsafe}${unsafe:+
}${docker_unsafe}"
  fi
  hash="$(hash_validation_inputs "$final_json")"
  rm -f "$base_json" "$expected_json" "$final_json" "$noenv_json" \
    "$raw_base_json" "$raw_final_json"

  if [ -n "$managed" ]; then
    printf 'aic: managed devcontainer validation failed:\n' >&2
    printf '%s\n' "$managed" | sed 's/^MANAGED[[:space:]]*/  ! /' >&2
    rm -f "$findings"
    [ "$mode" = "warn" ] && return 1
    [ "$mode" = "validate" ] && die "configuration is invalid (run 'aic sync', then review the diff)"
    die "refusing to start unverified managed configuration (run 'aic sync', then review the diff)"
  fi

  if [ -z "$unsafe" ] && [ -z "$volatile" ]; then
    rm -f "$findings"
    if [ "$mode" = "trust" ]; then
      echo "aic: no unsafe host-boundary expansions found; no trust exception is needed."
    fi
    return 0
  fi

  printf 'aic: resolved project configuration requests extra host access:\n' >&2
  printf '%s\n%s\n' "$unsafe" "$volatile" | sed -e '/^$/d' -e 's/^UNSAFE[[:space:]]*/  ! /' \
    -e 's/^DOCKER[[:space:]]*/  ! /' -e 's/^VOLATILE[[:space:]]*/  ! /' >&2
  rm -f "$findings"

  if [ "$mode" = "warn" ]; then
    return 1
  fi
  if [ -z "$volatile" ] && { [ "$mode" = "gate" ] || [ "$mode" = "validate" ]; } && project_trust_matches "$hash"; then
    return 0
  fi
  if [ "$mode" = "validate" ]; then
    [ -z "$volatile" ] || die "configuration includes an unbounded build context; use --allow-unsafe on each up/rebuild after reviewing it"
    die "unsafe configuration is not trusted; review it, then run 'aic trust' interactively"
  fi
  # Internal hand-off for `aic up/rebuild --allow-unsafe`: initializeCommand is
  # a child process and revalidates the exact same config before Compose starts.
  # A hash (not a boolean) prevents the repository changing configuration in
  # between the two checks and inheriting the one-run exception.
  if [ "$mode" = "gate" ] && [ "${AIC_UNSAFE_ONCE_HASH:-}" = "$hash" ]; then
    return 0
  fi
  if [ "$allow_once" = "1" ]; then
    export AIC_UNSAFE_ONCE_HASH="$hash"
    echo "aic: proceeding once because --allow-unsafe was explicitly supplied." >&2
    return 0
  fi

  if [ "$mode" = "trust" ] && [ -n "$volatile" ]; then
    die "persistent trust is unavailable for build contexts outside .devcontainer; use --allow-unsafe per run"
  fi
  if [ "$mode" = "trust" ] || [ -t 0 ]; then
    local reply
    printf "aic: trust this exact configuration%s? [y/N] " "$([ "$mode" = "trust" ] && printf '' || printf ' and continue')" >&2
    IFS= read -r reply || reply=""
    case "$reply" in
      y|Y|yes|YES)
        if [ -n "$volatile" ]; then
          echo "aic: proceeding once; persistent trust is unavailable for this build context."
        else
          store_project_trust "$hash"
          echo "aic: trusted this exact configuration; any relevant change invalidates the approval."
        fi
        return 0
        ;;
      *) die "aborted — configuration was not trusted" ;;
    esac
  fi
  die "unsafe configuration is not trusted; run 'aic trust' interactively or pass --allow-unsafe for one run"
}

cmd_trust () {
  require_in_project
  local revoke=0
  while [ $# -gt 0 ]; do
    case "$1" in
      --revoke) revoke=1 ;;
      *) die "unknown trust flag: $1 (try --revoke)" ;;
    esac
    shift
  done
  if [ "$revoke" = "1" ]; then
    rm -f "$(trust_state_file)"
    echo "aic: revoked this project's host-access trust."
    return 0
  fi
  [ -t 0 ] || die "'aic trust' requires an interactive confirmation"
  validate_project_security trust 0
}

# Print the trust boundary for the current project: what the agent can read,
# write, and reach. Folded into `aic up` (mode=up always reports network OPEN,
# since a freshly (re)created container never has the opt-in firewall applied)
# and exposed standalone as `aic preflight` (live-detects the firewall state).
# The protections are real but otherwise invisible — this makes them auditable.
# See the README "What crosses the boundary" table for the canonical version.
print_boundary_summary () {
  local mode="${1:-preflight}" project net
  project="$(project_name)"
  if [ "$mode" = "up" ]; then net="open"; else net="$(firewall_live_state)"; fi

  local b r y dim rst
  if [ -t 1 ]; then
    b=$'\033[1m'; r=$'\033[31m'; y=$'\033[33m'; dim=$'\033[2m'; rst=$'\033[0m'
  else
    b=""; r=""; y=""; dim=""; rst=""
  fi

  printf "\n%saic: trust boundary for project '%s'%s\n\n" "$b" "$project" "$rst"

  printf "  %sFilesystem%s\n" "$b" "$rst"
  printf "    rw   /workspace                               your project (the only writable host path)\n"
  printf "    ro   /host-seed/*.json                        root-sanitized, allowlisted preferences\n"
  printf "    ro   .devcontainer/ .git/config .git/hooks     AI cannot rewrite its own sandbox\n"
  printf "    %s--   raw host config, host home, ~/.ssh, host credentials: NOT mounted%s\n" "$dim" "$rst"

  printf "\n  %sSecrets%s\n" "$b" "$rst"
  printf "    .env* reads/writes blocked by the PreToolUse hook (fires even in bypass mode)\n"
  printf "    %syour project's own .env still lives in /workspace: the hook gates the agent, not the file%s\n" "$dim" "$rst"
  printf "    tool login: only four validated JSON credential files cross projects via a networkless sidecar\n"
  printf "    git credentials: none forwarded (you auth fresh inside); global Git config is root-owned under /etc\n"

  # Commit signing: the host signing key is never forwarded, so signing only
  # works here via a sandbox key set up with `aic signing`. Surface the state
  # so a host that signs commits doesn't hit a cryptic failure (or silently
  # push unsigned commits) without warning.
  local sg_st sg_mode sg_key sg_host
  sg_st="$(signing_state 2>/dev/null)" || sg_st="mode= key=0"
  sg_mode="${sg_st#mode=}"; sg_mode="${sg_mode%% key=*}"
  sg_key="${sg_st##*key=}"
  sg_host="$(git config --global --get commit.gpgsign 2>/dev/null || true)"
  if [ "$sg_mode" = "disabled" ]; then
    printf "    commit signing: disabled in sandbox (via 'aic signing')\n"
  elif [ "$sg_key" = "1" ]; then
    printf "    commit signing: sandbox ssh key (register its pubkey on GitHub to verify)\n"
  elif [ "$sg_host" = "true" ]; then
    printf "    %s! commit signing: host signs, but its key isn't here%s — commits unsigned; run 'aic signing'\n" "$y" "$rst"
  fi

  printf "\n  %sSessions%s\n" "$b" "$rst"
  if docker volume inspect "${project}_aic-sessions" >/dev/null 2>&1; then
    printf "    full tool homes -> volume %s_aic-sessions  (project-only; survives rebuild)\n" "$project"
  else
    printf "    full tool homes -> volume %s_aic-sessions  (created on first 'aic up')\n" "$project"
  fi
  printf "    shared globally: tool login JSON, gh/npm auth, signing key, shell history\n"

  printf "\n  %sDocker daemon%s\n" "$b" "$rst"
  case "$(read_compose_docker_mode)" in
    rw)
      printf "    %s! READ-WRITE socket-proxy%s: the agent can create/build containers on the HOST\n" "$r" "$rst"
      printf "      daemon (a container-escape vector, and sibling containers dodge the firewall).\n"
      printf "    %sreduce to reads: aic sync --docker-read; disable: aic sync --no-docker%s\n" "$dim" "$rst"
      ;;
    ro)
      printf "    %s! READ socket-proxy%s: host Docker APIs can expose containers' metadata, logs, and files\n" "$y" "$rst"
      printf "      to the agent; it cannot create or build containers.\n"
      printf "    %sdisable with: aic sync --no-docker && aic rebuild%s\n" "$dim" "$rst"
      ;;
    none)
      printf "    object APIs disabled: ping/version only; host containers/images/volumes are hidden\n"
      printf "    %senable only if needed: --docker-read (inspect) or --docker (read-write)%s\n" "$dim" "$rst"
      ;;
    *)
      printf "    %s! invalid managed proxy toggle set — run 'aic sync --no-docker'%s\n" "$r" "$rst"
      ;;
  esac

  printf "\n  %sNetwork%s\n" "$b" "$rst"
  printf "    %scloud metadata / link-local (169.254.0.0/16) blocked by default on every create%s\n" "$dim" "$rst"
  case "$net" in
    on)
      printf "    %s* firewall ENABLED%s  (default DROP + curated allowlist active)\n" "$b" "$rst"
      ;;
    unknown)
      printf "    %s! full outbound by default%s: internet and your LAN (metadata excepted, see above)\n" "$y" "$rst"
      printf "    %s(container not running: live firewall state unknown)%s\n" "$dim" "$rst"
      printf "    lock down:  aic shell  ->  sudo aic-firewall enable\n"
      ;;
    *)
      printf "    %s! FULL OUTBOUND%s: reaches the internet and your LAN (metadata excepted, see above)\n" "$r" "$rst"
      printf "    lock down per-project:  aic shell  ->  sudo aic-firewall enable\n"
      ;;
  esac

  if [ -f .devcontainer/docker-compose.override.yml ] || [ -f .devcontainer/firewall-allowlist ]; then
    printf "\n  %sProject overrides%s\n" "$b" "$rst"
    if [ -f .devcontainer/docker-compose.override.yml ]; then
      printf "    %s! docker-compose.override.yml present%s: may add mounts/env/hosts; review it.\n" "$y" "$rst"
    fi
    if [ -f .devcontainer/firewall-allowlist ]; then
      local fwcount; fwcount="$(grep -cvE '^[[:space:]]*(#|$)' .devcontainer/firewall-allowlist 2>/dev/null)" || fwcount=0
      printf "    firewall-allowlist present (%s domains): applied when you enable the firewall.\n" "$fwcount"
    fi
  fi

  printf "\n  %sFull model:%s README \"Threat model\" + \"What crosses the boundary\".\n\n" "$dim" "$rst"
}

# ---------------------------------------------------------------------------
# Commit signing inside the sandbox.
#
# The host's signing key never enters the container — ~/.ssh and the SSH agent
# are deliberately NOT forwarded (see the threat model). So a host configured
# for SSH/GPG commit signing can't sign here: every `git commit` would fail
# with "Couldn't find key in agent". `aic signing` fixes that without weakening
# the boundary, by provisioning a *sandbox-only* ed25519 signing key inside the
# aic-auth-global volume (register its pubkey on GitHub once, as a Signing Key).
# post-create wires it into the container-local gitconfig on the next (re)create
# — nothing is forwarded and the host gitconfig stays read-only.
#
# Mode is persisted as ~/.config/aic-auth/signing/mode in the volume:
#   auto     generate a sandbox signing key (recommended)
#   byok     install a separate signing key you provide
#   disable  turn commit signing off inside the sandbox
# `status` reports the current state. Mutating actions run as `vscode` inside
# the running container (so the key lands with correct owner + 0600 perms), so
# they need the container up; `status` reads the volume directly and works
# anytime. Because the wiring is compiled into the root-owned global config
# only at create time, a mode change takes effect on the next rebuild — no live
# edit, hence no privileged unlock primitive to abuse.
# ---------------------------------------------------------------------------

# Read the persisted signing state from the aic-auth-global volume without
# requiring a running container (or auto-creating the volume). Echoes
# "mode=<m> key=<0|1>"; always succeeds.
signing_state () {
  docker volume inspect aic-auth-global >/dev/null 2>&1 || { printf "mode= key=0"; return; }
  if ! docker_volume_metadata_is_safe aic-auth-global; then
    err "refusing to inspect aic-auth-global: managed volumes must use Docker's local driver with no driver options"
    printf "mode= key=0"
    return
  fi
  docker run --rm --network none --read-only --cap-drop ALL \
    --security-opt no-new-privileges:true -v aic-auth-global:/v:ro \
    busybox@sha256:fd8d9aa63ba2f0982b5304e1ee8d3b90a210bc1ffb5314d980eb6962f1a9715d sh -c \
    'printf "mode=%s key=%s" "$(cat /v/signing/mode 2>/dev/null)" "$(test -f /v/signing/id_ed25519 && echo 1 || echo 0)"' \
    2>/dev/null || printf "mode= key=0"
}

# True when this project's devcontainer is up (mutating signing actions exec
# into it). Mirrors firewall_live_state's running-container probe.
signing_container_running () {
  local project template cid
  project="$(project_name)"
  template="$(trusted_compose_template)"
  cid="$(docker compose -p "$project" -f "$template" ps -q devcontainer 2>/dev/null)" || return 1
  [ -n "$cid" ] || return 1
  [ "$(docker inspect -f '{{.State.Running}}' "$cid" 2>/dev/null)" = "true" ]
}

signing_print_status () {
  local st mode key host_sign
  st="$(signing_state)"
  mode="${st#mode=}"; mode="${mode%% key=*}"
  key="${st##*key=}"
  host_sign="$(git config --global --get commit.gpgsign 2>/dev/null || true)"
  printf "aic: commit signing (sandbox-only, shared across projects)\n"
  if [ "$mode" = "disabled" ]; then
    printf "  mode: disabled — commits are unsigned inside the sandbox\n"
  elif [ "$key" = "1" ]; then
    printf "  mode: %s — sandbox ssh signing key present\n" "${mode:-auto}"
    printf "  note: register its pubkey on GitHub as a Signing Key if you haven't (else commits show Unverified)\n"
  elif [ "$host_sign" = "true" ]; then
    printf "  mode: unconfigured — your host signs commits, but that key isn't in the sandbox\n"
    printf "  note: commits are UNSIGNED here; run 'aic signing auto' to provision a sandbox key\n"
  else
    printf "  mode: unconfigured — host doesn't sign commits, nothing to set up\n"
  fi
}

# Simple numbered chooser (host TTY). Echoes the chosen action; returns 1 on
# cancel. Kept deliberately plain — no raw-mode arrow UI needed for 3 options.
signing_menu () {
  local reply
  printf "\nSet up sandbox commit signing:\n" >&2
  printf "  1) auto     generate a sandbox signing key (recommended)\n" >&2
  printf "  2) byok     install a signing key you provide\n" >&2
  printf "  3) disable  turn commit signing off in the sandbox\n" >&2
  printf "  q) cancel\n" >&2
  printf "choice [1]: " >&2
  IFS= read -r reply || reply=""
  case "$reply" in
    ""|1) echo auto ;;
    2)    echo byok ;;
    3)    echo disable ;;
    q|Q)  return 1 ;;
    *)    die "invalid choice: $reply" ;;
  esac
}

signing_do_auto () {
  local devcontainer="$1" register="$2" pub
  # Generate (or reuse) the key as vscode inside the container; emit only the
  # public key on stdout so we can capture it, diagnostics on stderr.
  pub="$("$devcontainer" exec --workspace-folder . bash -lc '
    set -euo pipefail
    dir="$HOME/.config/aic-auth/signing"; key="$dir/id_ed25519"
    mkdir -p "$dir"
    if [ ! -f "$key" ]; then
      ssh-keygen -t ed25519 -N "" -C "aicontainer sandbox signing key" -f "$key" >/dev/null
      echo "aic: generated sandbox signing key" >&2
    else
      echo "aic: reusing existing sandbox signing key" >&2
    fi
    chmod 600 "$key"
    printf auto > "$dir/mode"
    cat "$key.pub"
  ')" || die "failed to set up the signing key inside the container"

  printf "\naic: sandbox signing key ready:\n\n  %s\n\n" "$pub"
  if [ "$register" = "1" ]; then
    signing_register "$devcontainer"
  else
    printf "aic: register it on GitHub as a *Signing Key* (not Authentication):\n"
    printf "       https://github.com/settings/ssh/new\n"
    printf "aic: until then, commits sign locally but show \"Unverified\" on GitHub.\n"
    printf "aic: (or re-run 'aic signing auto --register' to add it via gh.)\n"
  fi
  printf "aic: then 'aic rebuild' (or VS Code: Rebuild Container) to activate signing.\n"
}

signing_register () {
  local devcontainer="$1"
  printf "aic: registering the signing key on GitHub via gh...\n"
  if "$devcontainer" exec --workspace-folder . bash -lc '
    set -euo pipefail
    gh api --method POST /user/ssh_signing_keys \
      -f "title=aicontainer ($(hostname))" \
      -f "key=$(cat "$HOME/.config/aic-auth/signing/id_ed25519.pub")" >/dev/null
  '; then
    printf "aic: registered as a signing key on your GitHub account.\n"
  else
    printf "aic: gh registration failed — most likely the gh token lacks the\n"
    printf "     'write:ssh_signing_key' scope. Grant it and retry:\n"
    printf "       aic shell  ->  gh auth refresh -h github.com -s write:ssh_signing_key\n"
    printf "     then re-run 'aic signing auto --register', or add the key by hand:\n"
    printf "       https://github.com/settings/ssh/new\n"
  fi
}

signing_do_byok () {
  local devcontainer="$1"
  if [ ! -t 0 ]; then
    # A private key is piped on stdin — install it (and derive the pubkey).
    "$devcontainer" exec --workspace-folder . bash -lc '
      set -euo pipefail
      dir="$HOME/.config/aic-auth/signing"; key="$dir/id_ed25519"
      mkdir -p "$dir"
      cat > "$key"
      chmod 600 "$key"
      ssh-keygen -y -f "$key" > "$key.pub"
      printf byok > "$dir/mode"
      echo "aic: installed your signing key:" >&2
      ssh-keygen -lf "$key.pub" >&2
    ' || die "failed to install the provided key (must be an unencrypted private key)"
    printf "aic: register the pubkey on GitHub as a Signing Key: https://github.com/settings/ssh/new\n"
    printf "aic: then 'aic rebuild' to activate signing.\n"
    return
  fi
  # No piped key — record the mode and explain how to drop one in.
  "$devcontainer" exec --workspace-folder . bash -lc '
    set -euo pipefail
    dir="$HOME/.config/aic-auth/signing"; mkdir -p "$dir"; printf byok > "$dir/mode"
  ' || die "failed to set signing mode in the container"
  cat <<'BYOK_EOF'
aic: bring-your-own-key mode set. Provide a *separate* signing key (not your
     host key) one of two ways:
       1) pipe it:   aic signing byok < /path/to/your_signing_key
       2) or place it in the container at
            ~/.config/aic-auth/signing/id_ed25519   (chmod 600)
          e.g. via 'aic shell'; aic derives the .pub if it's absent.
aic: register the pubkey on GitHub as a Signing Key, then 'aic rebuild'.
BYOK_EOF
}

signing_do_disable () {
  local devcontainer="$1"
  "$devcontainer" exec --workspace-folder . bash -lc '
    set -euo pipefail
    dir="$HOME/.config/aic-auth/signing"; mkdir -p "$dir"; printf disabled > "$dir/mode"
  ' || die "failed to set signing mode in the container"
  printf "aic: commit signing will be DISABLED inside the sandbox.\n"
  printf "aic: run 'aic rebuild' (or VS Code: Rebuild Container) to apply.\n"
}

cmd_signing () {
  require_in_project
  local action="" register=0
  while [ $# -gt 0 ]; do
    case "$1" in
      auto|byok|disable|status) action="$1" ;;
      --register) register=1 ;;
      *) die "unknown signing argument: $1 (try: auto, byok, disable, status [--register])" ;;
    esac
    shift
  done

  # No explicit action: print status, then offer the chooser on a TTY.
  if [ -z "$action" ]; then
    signing_print_status
    if [ -t 0 ] && [ -t 1 ]; then
      action="$(signing_menu)" || { echo "aic: cancelled."; return 0; }
    else
      return 0
    fi
  fi

  if [ "$action" = "status" ]; then
    signing_print_status
    return 0
  fi

  # Mutating actions run inside the container (as vscode) — needs it up.
  # devcontainer exec consumes the repository configuration, so gate it before
  # the running-container probe or any key operation.
  write_runtime_environment_file
  validate_project_security gate 0
  if ! signing_container_running; then
    die "container not running — run 'aic up' first, then 'aic signing $action'"
  fi
  local devcontainer; devcontainer="$(resolve_devcontainer)"
  case "$action" in
    auto)    signing_do_auto "$devcontainer" "$register" ;;
    byok)    signing_do_byok "$devcontainer" ;;
    disable) signing_do_disable "$devcontainer" ;;
  esac
}

# Copy the legacy basename-scoped transcript volume into the new path-hashed
# volume exactly once. The source stays intact because another same-basename
# checkout may have shared it under the historical naming scheme. The helper
# image is digest-pinned and runs without network, with only the narrow file
# ownership capabilities required by the copy; it is the same bootstrap image
# used by the managed initializeCommand.

# A Compose declaration cannot make a pre-created physical Docker volume safe:
# the same name may already point at a local-driver bind mount (or a volume
# plugin). Inspect the daemon object itself before any fixed helper mounts or
# chowns it. Only ordinary local volumes with no driver options are accepted.
docker_volume_metadata_is_safe () {
  local name="$1" metadata
  metadata="$(docker volume inspect --format '{{json .}}' "$name" 2>/dev/null)" || return 1
  node -e '
    let volume;
    try { volume = JSON.parse(process.argv[1]); } catch (_) { process.exit(2); }
    const options = volume && volume.Options;
    const emptyOptions = options == null ||
      (typeof options === "object" && !Array.isArray(options) && Object.keys(options).length === 0);
    if (!volume || volume.Driver !== "local" || !emptyOptions) process.exit(1);
  ' "$metadata" >/dev/null 2>&1
}

assert_safe_docker_volume () {
  local name="$1"
  docker volume inspect "$name" >/dev/null 2>&1 || \
    die "managed Docker volume is missing or cannot be inspected: $name"
  docker_volume_metadata_is_safe "$name" || \
    die "refusing unsafe managed volume '$name' (requires Driver=local with no driver options)"
}

assert_safe_docker_volume_if_present () {
  local name="$1"
  docker volume inspect "$name" >/dev/null 2>&1 || return 0
  assert_safe_docker_volume "$name"
}

ensure_safe_docker_volume () {
  local name="$1"
  docker volume create "$name" >/dev/null || die "could not create managed Docker volume: $name"
  assert_safe_docker_volume "$name"
}

# Basename-scoped projects could collide historically, so the old volume name
# alone is never ownership evidence. Require a container whose inspected labels
# identify this exact canonical workspace and legacy Compose project, and whose
# actual mount table attaches this exact volume at one of the two session-root
# paths used by aicontainer. Docker filters narrow the candidates; the explicit
# inspect comparison is the security check.
legacy_session_volume_owned_by_workspace () {
  local old_vol="$1" legacy="$2" workspace candidates users cid inspected proved=0
  workspace="$(pwd -P)"
  candidates="$(docker ps -aq \
    --filter "label=devcontainer.local_folder=$workspace" \
    --filter "label=com.docker.compose.project=$legacy" 2>/dev/null)" || return 1
  [ -n "$candidates" ] || return 1

  while IFS= read -r cid; do
    [ -n "$cid" ] || continue
    inspected="$(docker inspect --format '{{json .}}' "$cid" 2>/dev/null)" || continue
    if node -e '
      let container;
      try { container = JSON.parse(process.argv[1]); } catch (_) { process.exit(2); }
      const labels = container && container.Config && container.Config.Labels;
      const mounts = container && container.Mounts;
      const destinations = new Set([
        "/home/vscode/.claude-sessions",
        "/home/vscode/.aic-sessions",
      ]);
      const owned = labels &&
        labels["devcontainer.local_folder"] === process.argv[2] &&
        labels["com.docker.compose.project"] === process.argv[3] &&
        Array.isArray(mounts) && mounts.some((mount) =>
          mount && mount.Type === "volume" &&
          mount.Name === process.argv[4] && destinations.has(mount.Destination));
      if (!owned) process.exit(1);
    ' "$inspected" "$workspace" "$legacy" "$old_vol" >/dev/null 2>&1; then
      proved=1
      break
    fi
  done <<< "$candidates"
  [ "$proved" = "1" ] || return 1

  # If a second checkout still has this basename-colliding volume attached,
  # even the exact container above cannot prove the data is workspace-private.
  # Treat every other label owner as ambiguity; sidecars from the same exact
  # workspace/project are harmless and may legitimately share the volume.
  users="$(docker ps -aq --filter "volume=$old_vol" 2>/dev/null)" || return 1
  [ -n "$users" ] || return 1
  while IFS= read -r cid; do
    [ -n "$cid" ] || continue
    inspected="$(docker inspect --format '{{json .}}' "$cid" 2>/dev/null)" || return 1
    node -e '
      let container;
      try { container = JSON.parse(process.argv[1]); } catch (_) { process.exit(2); }
      const labels = container && container.Config && container.Config.Labels;
      const mounts = container && container.Mounts;
      const usesVolume = Array.isArray(mounts) && mounts.some((mount) =>
        mount && mount.Type === "volume" && mount.Name === process.argv[4]);
      if (!usesVolume) process.exit(1);
      const sameOwner = labels &&
        labels["devcontainer.local_folder"] === process.argv[2] &&
        labels["com.docker.compose.project"] === process.argv[3];
      if (!sameOwner) process.exit(1);
    ' "$inspected" "$workspace" "$legacy" "$old_vol" >/dev/null 2>&1 || return 1
  done <<< "$users"
  return 0
}

migrate_legacy_session_volume () {
  local mode="${1:-strict}" legacy expected old_vol new_vol image reply
  legacy="$(legacy_project_name)"; expected="$(expected_project_name)"
  [ "$legacy" != "$expected" ] || return 0
  old_vol="${legacy}_aic-sessions"
  new_vol="${expected}_aic-sessions"
  image="busybox@sha256:fd8d9aa63ba2f0982b5304e1ee8d3b90a210bc1ffb5314d980eb6962f1a9715d"

  if ! docker info >/dev/null 2>&1; then
    [ "$mode" = "defer" ] && return 0
    die "Docker is unavailable; cannot check/migrate the legacy sessions volume"
  fi
  docker volume inspect "$old_vol" >/dev/null 2>&1 || return 0
  if docker volume inspect "$new_vol" >/dev/null 2>&1; then
    assert_safe_docker_volume "$new_vol"
    return 0
  fi

  if ! legacy_session_volume_owned_by_workspace "$old_vol" "$legacy"; then
    err "legacy session volume '$old_vol' cannot be uniquely tied to this workspace."
    if [ "$mode" = "defer" ]; then
      err "leaving it untouched; run 'aic up' in an interactive terminal to choose whether to import it."
      return 0
    fi
    if [ ! -t 0 ]; then
      die "the legacy volume was preserved; run 'aic up' in an interactive terminal to choose import or a fresh isolated session volume"
    fi
    printf "aic: import this ambiguous legacy volume into this workspace? [y/N] " >&2
    IFS= read -r reply || reply=""
    case "$reply" in
      y|Y|yes|YES) ;;
      *)
        ensure_safe_docker_volume "$new_vol"
        echo "aic: legacy volume preserved and not imported; this workspace will use a fresh isolated session volume."
        return 0
        ;;
    esac
  fi

  assert_safe_docker_volume "$old_vol"
  echo "aic: migrating legacy session transcripts: $old_vol → $new_vol"
  ensure_safe_docker_volume "$new_vol"
  if ! docker run --rm --network none --read-only --cap-drop ALL \
      --cap-add CHOWN --cap-add FOWNER --cap-add DAC_OVERRIDE \
      --security-opt no-new-privileges:true \
      -v "$old_vol:/from:ro" -v "$new_vol:/to" \
      "$image" sh -c 'cp -a /from/. /to/'; then
    docker volume rm "$new_vol" >/dev/null 2>&1 || true
    [ "$mode" = "defer" ] && { err "session migration deferred after the copy failed"; return 0; }
    die "could not copy the legacy sessions volume; the original remains untouched"
  fi
  echo "aic: session migration complete (the legacy source volume was preserved)."
}

# Host-side volume/bootstrap work shared by `aic up` and direct VS Code starts.
# Fixed paths only: repository input never becomes a helper command argument.
prepare_host_seed_paths () {
  local dir file
  [ -n "${HOME:-}" ] || die "HOME is not set; cannot prepare host configuration seeds"
  for dir in "$HOME/.claude" "$HOME/.codex" "$HOME/.config" "$HOME/.config/opencode"; do
    if [ -e "$dir" ] || [ -L "$dir" ]; then
      [ -d "$dir" ] || die "host seed parent exists but is not a directory: $dir"
    else
      mkdir -p "$dir" || die "could not create host seed parent: $dir"
    fi
  done
  for file in "$HOME/.gitconfig" "$HOME/.claude/settings.json" \
    "$HOME/.codex/config.toml" "$HOME/.config/opencode/opencode.json"; do
    if [ -e "$file" ] || [ -L "$file" ]; then
      [ -f "$file" ] || die "host seed path exists but is not a regular file: $file"
    else
      touch "$file" || die "could not create host seed file: $file"
    fi
  done
}

initialize_managed_volumes () {
  local project sessions seed image identity uid gid
  project="$(project_name)"
  sessions="${project}_aic-sessions"
  seed="${project}_aic-sanitized-seed"
  image="busybox@sha256:fd8d9aa63ba2f0982b5304e1ee8d3b90a210bc1ffb5314d980eb6962f1a9715d"
  identity="$(runtime_user_id)"; uid="${identity%%:*}"; gid="${identity##*:}"

  ensure_safe_docker_volume aic-auth-global
  ensure_safe_docker_volume aic-shell-history
  ensure_safe_docker_volume "$sessions"
  # Compose creates this per-project output volume when absent. If it was
  # pre-created, validate its physical backing before the root sanitizer gets
  # a chance to write through it.
  assert_safe_docker_volume_if_present "$seed"

  # Only exact credential directories remain global. Whole Claude/Codex/
  # OpenCode homes now live in the per-project sessions volume; a networkless
  # sidecar reconciles four validated credential files between the two. Create
  # the volume.subpath roots before Compose resolves them, and align ownership
  # with Dev Containers' host-UID mapping.
  if ! docker run --rm --network none --read-only --cap-drop ALL \
    --cap-add CHOWN --cap-add FOWNER --cap-add DAC_OVERRIDE \
    --security-opt no-new-privileges:true \
    -e AIC_UID="$uid" -e AIC_GID="$gid" \
    -v aic-auth-global:/v -v aic-shell-history:/history "$image" sh -c '
      set -eu
      ensure_dir() {
        p=$1
        if [ -L "$p" ] || { [ -e "$p" ] && [ ! -d "$p" ]; }; then rm -rf "$p"; fi
        mkdir -p "$p"
        chmod 0700 "$p"
      }
      for p in /v/claude /v/codex /v/opencode /v/gh /v/npm /v/signing /v/semgrep /history
      do
        ensure_dir "$p"
      done
      chown -h -R "$AIC_UID:$AIC_GID" \
        /v/claude /v/codex /v/opencode /v/gh /v/npm /v/signing /v/semgrep /history
    '; then
    die "could not prepare managed auth-volume subpaths"
  fi

  # Transparently migrate the old ~/.claude-sessions layout inside the same
  # physical per-project volume. A clean destination is renamed atomically;
  # after a partial prior migration, copy only missing entries and preserve the
  # legacy source so recovery never destroys the sole copy.
  if ! docker run --rm --network none --read-only --cap-drop ALL \
    --cap-add CHOWN --cap-add FOWNER --cap-add DAC_OVERRIDE \
    --security-opt no-new-privileges:true \
    -e AIC_UID="$uid" -e AIC_GID="$gid" -v "$sessions:/v" "$image" sh -c '
      set -eu
      ensure_dir() {
        p=$1
        if [ -L "$p" ] || { [ -e "$p" ] && [ ! -d "$p" ]; }; then rm -rf "$p"; fi
        mkdir -p "$p"
        chmod 0700 "$p"
      }
      migrate() {
        src=$1; dst=$2
        [ -e "$src" ] || [ -L "$src" ] || return 0
        # Never follow an agent-planted link while this fixed root helper owns
        # the volume. A link is not valid session data in either layout.
        if [ -L "$src" ]; then rm -f "$src"; return 0; fi
        mkdir -p "$(dirname "$dst")"
        if [ ! -e "$dst" ] && [ ! -L "$dst" ]; then
          mv "$src" "$dst"
        elif [ -d "$src" ] && [ -d "$dst" ] && [ ! -L "$dst" ]; then
          cp -a -n "$src"/. "$dst"/ 2>/dev/null || true
        fi
      }

      migrate /v/claude-projects       /v/tool-homes/claude/projects
      migrate /v/claude-history.jsonl  /v/tool-homes/claude/history.jsonl
      migrate /v/claude-settings.json  /v/tool-homes/claude/settings.json
      migrate /v/claude-memory.md       /v/tool-homes/claude/CLAUDE.md
      migrate /v/claude-skills          /v/tool-homes/claude/skills
      migrate /v/claude-agents          /v/tool-homes/claude/agents
      migrate /v/claude-commands        /v/tool-homes/claude/commands
      migrate /v/claude-plugins         /v/tool-homes/claude/plugins

      migrate /v/codex-sessions         /v/tool-homes/codex/sessions
      migrate /v/codex-history.jsonl    /v/tool-homes/codex/history.jsonl
      migrate /v/codex-config.toml       /v/tool-homes/codex/config.toml
      migrate /v/codex-memory.md        /v/tool-homes/codex/AGENTS.md
      migrate /v/codex-skills           /v/tool-homes/codex/skills
      migrate /v/codex-rules            /v/tool-homes/codex/rules
      migrate /v/codex-prompts          /v/tool-homes/codex/prompts
      migrate /v/codex-plugins          /v/tool-homes/codex/plugins

      migrate /v/opencode               /v/tool-homes/opencode-data
      migrate /v/opencode-storage       /v/tool-homes/opencode-data/storage
      migrate /v/opencode-snapshot      /v/tool-homes/opencode-data/snapshot

      for p in \
        /v/tool-homes /v/tool-homes/claude /v/tool-homes/codex \
        /v/tool-homes/opencode-config /v/tool-homes/opencode-data
      do
        ensure_dir "$p"
      done
      chown -h -R "$AIC_UID:$AIC_GID" /v
    '; then
    die "could not migrate/prepare the per-project tool homes"
  fi

  # The sanitizer is a one-shot service. Remove its exited container so every
  # create re-runs it and refreshes allowlisted host preferences.
  docker compose -p "$project" -f "$(trusted_compose_template)" rm -sf aic-seed-sanitizer >/dev/null 2>&1 || true
}

# After sync, an old devcontainer stack may still be running under the legacy
# name. `compose down` acts on the whole project, so one owned devcontainer is
# insufficient evidence: inspect every legacy-project container. At least one
# must carry this exact canonical workspace label; only fixed aic sidecars may
# omit it (Dev Containers labels the primary service, not necessarily Compose
# dependencies). A different owner, unknown unlabeled service, or unreadable
# container preserves the stack rather than risking collateral damage to
# another same-basename checkout. Never use --remove-orphans here: those are
# precisely the services the trusted managed template cannot attribute.
stop_owned_legacy_stack () {
  local legacy expected workspace containers cid inspected template proved=0
  legacy="$(legacy_project_name)"; expected="$(expected_project_name)"
  [ "$legacy" != "$expected" ] || return 0
  workspace="$(pwd -P)"
  if ! containers="$(docker ps -aq \
      --filter "label=com.docker.compose.project=$legacy" 2>/dev/null)"; then
    err "could not verify ownership of legacy Compose stack '$legacy'; preserving it."
    return 0
  fi
  [ -n "$containers" ] || return 0

  while IFS= read -r cid; do
    [ -n "$cid" ] || continue
    if ! inspected="$(docker inspect --format '{{json .}}' "$cid" 2>/dev/null)"; then
      err "legacy Compose stack '$legacy' has an unreadable container owner; preserving the whole stack."
      return 0
    fi
    if node -e '
      let container;
      try { container = JSON.parse(process.argv[1]); } catch (_) { process.exit(2); }
      const labels = container && container.Config && container.Config.Labels;
      const owned = labels &&
        labels["devcontainer.local_folder"] === process.argv[2] &&
        labels["com.docker.compose.project"] === process.argv[3];
      if (!owned) process.exit(1);
    ' "$inspected" "$workspace" "$legacy" >/dev/null 2>&1; then
      proved=1
      continue
    fi
    if node -e '
      let container;
      try { container = JSON.parse(process.argv[1]); } catch (_) { process.exit(2); }
      const labels = container && container.Config && container.Config.Labels;
      const allowed = new Set(["socket-proxy", "aic-auth-sync", "aic-seed-sanitizer"]);
      const auxiliary = labels &&
        labels["com.docker.compose.project"] === process.argv[2] &&
        !labels["devcontainer.local_folder"] &&
        allowed.has(labels["com.docker.compose.service"]);
      if (!auxiliary) process.exit(1);
    ' "$inspected" "$legacy" >/dev/null 2>&1; then
      continue
    fi
    err "legacy Compose stack '$legacy' includes a container not provably owned by this exact workspace; preserving the whole stack."
    return 0
  done <<< "$containers"
  if [ "$proved" != "1" ]; then
    err "legacy Compose stack '$legacy' has no container proving ownership by this workspace; preserving the whole stack."
    return 0
  fi

  echo "aic: stopping this workspace's legacy Compose stack '$legacy' (current managed name: '$expected')"
  template="$(trusted_compose_template)"
  docker compose -p "$legacy" -f "$template" down \
    || err "could not stop legacy stack '$legacy'; continuing with the isolated project name"
}

cmd_up () {
  require_in_project
  write_runtime_environment_file
  local allow_unsafe=0 arg
  local -a args=()
  for arg in "$@"; do
    case "$arg" in
      --allow-unsafe) allow_unsafe=1 ;;
      *) args+=("$arg") ;;
    esac
  done
  # Keep the readable raw warning, then enforce structural + resolved-Compose
  # validation. Ordinary generated projects produce no prompt or extra output.
  scan_project_overrides warn
  validate_project_security gate "$allow_unsafe"
  migrate_legacy_session_volume strict
  stop_owned_legacy_stack
  local devcontainer; devcontainer="$(resolve_devcontainer)"
  if [ "${#args[@]}" -gt 0 ]; then
    "$devcontainer" up --workspace-folder . "${args[@]}"
  else
    "$devcontainer" up --workspace-folder .
  fi
  print_boundary_summary up
  warn_compose_drift
}

cmd_preflight () {
  require_in_project
  # Review-only: surface all findings without prompting, persisting trust, or
  # failing before the boundary summary. `aic validate` is the strict CI gate.
  validate_project_security warn 0 || true
  print_boundary_summary preflight
}

# Internal. Surface the Tier-1 drift warning from a non-aic entry point: the
# template's devcontainer.json `initializeCommand` calls this so a VS Code
# "Reopen/Rebuild in Container" — which drives `devcontainer up` directly and
# never the aic CLI — still gets the nudge that `aic up`/`shell`/`rebuild` print.
# Deliberately lenient and undocumented (no require_in_project, always exits 0):
# it runs inside the host-side initializeCommand chain, where a non-zero exit
# would abort container startup, and outside a project it must simply no-op.
# warn_compose_drift already covers both (empty pin / broken read → return 0).
# Output lands in VS Code's Dev Containers output channel, not the terminal.
cmd_check_drift () {
  # Run path validation in a subshell so the internal entry point can preserve
  # its always-zero contract while refusing to read any symlinked control file.
  (validate_devcontainer_paths optional) || return 0
  warn_compose_drift
  # Same host-side entry point surfaces the override scan (print-only) so a
  # VS Code "Reopen/Rebuild in Container" gets it in the Dev Containers output
  # channel. Never prompts, always exits 0 (initializeCommand must not abort).
  scan_project_overrides warn
  # Reusable full validation, warn-only until every generated template has the
  # trusted `aic initialize` hook. Never let the legacy check-drift entry point
  # abort VS Code startup.
  if [ -z "${AIC_NO_OVERRIDE_SCAN:-}" ]; then
    validate_project_security warn 0 || true
  fi
}

# Internal managed initialize entry point for VS Code / devcontainer CLI. Once
# the generated initializer is invoked, it applies the same fail-closed gate
# and migration as `aic up` before Compose starts. Dev Containers necessarily
# reads the repository command first, so unknown repo-supplied configuration
# still has to be regenerated/reviewed before a direct editor bootstrap.
cmd_initialize () {
  require_in_project
  # Refresh the host-specific, gitignored socket path before either our own
  # resolved-Compose validation or the parent Dev Containers process uses it.
  write_runtime_environment_file
  validate_project_security gate 0
  prepare_host_seed_paths
  migrate_legacy_session_volume strict
  stop_owned_legacy_stack
  initialize_managed_volumes
  warn_compose_drift
}

cmd_rebuild () {
  require_in_project
  write_runtime_environment_file
  local allow_unsafe=0 arg
  local -a args=()
  for arg in "$@"; do
    case "$arg" in
      --allow-unsafe) allow_unsafe=1 ;;
      *) args+=("$arg") ;;
    esac
  done
  scan_project_overrides warn
  validate_project_security gate "$allow_unsafe"
  migrate_legacy_session_volume strict
  stop_owned_legacy_stack
  # Warn *before* the pull below: `aic rebuild` re-pulls the *currently pinned*
  # tag (it never re-pins), so on post-`npm update` drift this would otherwise
  # silently re-fetch the stale image. Surfacing it here lets the user abort and
  # `aic sync` first instead of waiting through a pull they'll discard.
  warn_compose_drift
  # Pull-mode compose pins `pull_policy: missing`, so `devcontainer up` reuses
  # the cached image even with --remove-existing-container — meaning newer
  # GHCR releases would be silently ignored. Force a pull so `aic rebuild`
  # actually refreshes the image. In --build mode the devcontainer service
  # has a `build:` block (no top-level `image:` on it), so we skip the pull
  # branch entirely; --build-no-cache below does the refresh for that path.
  # Detect mode via presence of Dockerfile, which apply_template only copies
  # in --build mode.
  if [ ! -f .devcontainer/Dockerfile ]; then
    local image
    image="$(awk '/^[[:space:]]*image:/ {sub(/^[[:space:]]*image:[[:space:]]*/, ""); sub(/[[:space:]]*#.*$/, ""); sub(/[[:space:]]+$/, ""); print; exit}' .devcontainer/docker-compose.yml 2>/dev/null || true)"
    if [ -n "$image" ]; then
      echo "aic: pulling $image"
      docker pull "$image" || echo "aic: docker pull failed; continuing with cached image" >&2
    fi
  fi
  local devcontainer; devcontainer="$(resolve_devcontainer)"
  # Bash 3.2 (still the system Bash on macOS) treats expansion of an empty
  # array as an unbound variable under `set -u`, even when it was declared.
  if [ "${#args[@]}" -gt 0 ]; then
    "$devcontainer" up --workspace-folder . --remove-existing-container --build-no-cache "${args[@]}"
  else
    "$devcontainer" up --workspace-folder . --remove-existing-container --build-no-cache
  fi
}

cmd_shell () {
  require_in_project
  write_runtime_environment_file
  # devcontainer exec parses repository control files even for an already-
  # running container. Revalidate them before handing them to the CLI.
  validate_project_security gate 0
  warn_compose_drift
  local devcontainer shell
  devcontainer="$(resolve_devcontainer)"
  # Honor the per-project shell choice (AIC_SHELL in devcontainer.json).
  # Older projects without the field fall back to zsh — that's what they had
  # baked in pre-flag.
  shell="$(read_aic_shell)"
  [ -n "$shell" ] || shell="$DEFAULT_SHELL"
  shell="$(validate_shell "$shell")"
  case "$shell" in
    zsh)
      "$devcontainer" exec --workspace-folder . zsh -l "$@"
      ;;
    bash)
      # A login bash reads writable ~/.bash_profile before ~/.bashrc. Start
      # from the root-owned managed rc directly so a prior unrestricted session
      # cannot plant persistence for the next shell.
      "$devcontainer" exec --workspace-folder . bash --noprofile --rcfile /etc/aic/shell/bashrc -i "$@"
      ;;
    fish)
      "$devcontainer" exec --workspace-folder . fish --no-config \
        -C 'source /etc/fish/conf.d/aic.fish' "$@"
      ;;
  esac
}

cmd_run () {
  require_in_project
  write_runtime_environment_file
  validate_project_security gate 0
  local devcontainer; devcontainer="$(resolve_devcontainer)"
  "$devcontainer" exec --workspace-folder . "$@"
}

trusted_compose_template () {
  if [ -f .devcontainer/Dockerfile ]; then
    printf '%s/docker-compose.build.yml\n' "$TEMPLATE_DIR"
  else
    printf '%s/docker-compose.pull.yml\n' "$TEMPLATE_DIR"
  fi
}

cmd_down () {
  require_in_project
  local project template
  if ! compose_has_project_name; then
    # Pre-migration cleanup is allowed only when Docker labels prove that the
    # legacy stack belongs to this exact canonical workspace. Never issue a
    # basename-scoped unconditional `compose down`.
    stop_owned_legacy_stack
    err "legacy project identity detected; run 'aic sync' before the next start"
    return 0
  fi
  project="$(project_name)"; template="$(trusted_compose_template)"
  # Cleanup deliberately parses only aic's installed trusted template. The
  # repository override may contain Compose providers/includes that execute
  # host-side code; --remove-orphans still removes every project-labelled
  # override service without evaluating that untrusted file.
  stop_owned_legacy_stack
  docker compose -p "$project" -f "$template" down --remove-orphans
}

# Best-effort on-disk size of a named volume, e.g. "123.4MB". Echoes "" if the
# volume doesn't exist or docker can't tell us. Uses `docker system df -v`
# (docker's own accounting — no helper container, works on a stopped container),
# matching the volume by exact name. Never blocks the caller.
volume_size () {
  local vol="$1"
  command -v docker >/dev/null 2>&1 || { echo ""; return; }
  docker volume inspect "$vol" >/dev/null 2>&1 || { echo ""; return; }
  docker system df -v 2>/dev/null | awk -v v="$vol" '$1==v {print $NF; found=1} END{if(!found) print ""}'
}

cmd_destroy () {
  require_in_project
  local project template assume_yes=0
  while [ $# -gt 0 ]; do
    case "$1" in
      -y|--yes) assume_yes=1 ;;
      *) die "unknown destroy flag: $1 (try --yes)" ;;
    esac
    shift
  done
  compose_has_project_name || \
    die "refusing to destroy a basename-scoped legacy project; run 'aic sync' first"
  project="$(project_name)"
  template="$(trusted_compose_template)"
  local vol="${project}_aic-sessions" seed_vol="${project}_aic-sanitized-seed" size
  size="$(volume_size "$vol")"

  echo "aic: 'aic destroy' will remove the container and these PER-PROJECT volumes for '$project':"
  if [ -n "$size" ]; then
    echo "       $vol  ($size of Claude/Codex/OpenCode session transcripts)"
  else
    echo "       $vol  (Claude/Codex/OpenCode session transcripts)"
  fi
  echo "       $seed_vol  (sanitized host configuration seed)"
  echo "aic: global volumes aic-auth-global and aic-shell-history are PRESERVED."
  echo "aic: this is irreversible. To stop the container but KEEP history, use 'aic down' instead."

  # Destructive non-interactive calls must be explicit. A closed stdin / CI
  # pipeline is never implicit consent to delete persistent transcripts.
  if [ "$assume_yes" -ne 1 ] && [ ! -t 0 ]; then
    die "refusing non-interactive destroy without --yes"
  fi
  if [ "$assume_yes" -ne 1 ]; then
    local reply
    printf "aic: destroy '%s' and delete the above? [y/N] " "$project"
    IFS= read -r reply || reply=""
    case "$reply" in
      y|Y|yes|YES) ;;
      *) echo "aic: aborted — nothing removed."; return 0 ;;
    esac
  fi

  stop_owned_legacy_stack
  docker compose -p "$project" -f "$template" down --volumes --remove-orphans
  docker volume rm "$vol" 2>/dev/null || true
  docker volume rm "$seed_vol" 2>/dev/null || true
  echo "aic: destroyed '$project' (container + per-project volumes removed)."
}

# Normalize the first dotted numeric version in a command's output. Docker and
# Compose commonly add a leading "v" or a vendor suffix; diagnostics only need
# the numeric compatibility floor.
diagnostic_version () {
  printf '%s\n' "$1" | grep -Eo '[0-9]+(\.[0-9]+){0,2}' | head -n1 || true
}

version_at_least () {
  local actual="$1" minimum="$2" i av mv
  local -a a m
  IFS=. read -ra a <<< "$actual"
  IFS=. read -ra m <<< "$minimum"
  for i in 0 1 2; do
    av="${a[i]:-0}"; mv="${m[i]:-0}"
    case "$av:$mv" in *[!0-9:]*|'':*) return 1 ;; esac
    av=$((10#$av)); mv=$((10#$mv))
    [ "$av" -gt "$mv" ] && return 0
    [ "$av" -lt "$mv" ] && return 1
  done
  return 0
}

doctor_ok ()   { printf 'OK    %s\n' "$*"; }
doctor_warn () {
  printf 'WARN  %s\n' "$*"
  doctor_warnings=$((doctor_warnings + 1))
}
doctor_fail () {
  printf 'FAIL  %s\n' "$*"
  doctor_failures=$((doctor_failures + 1))
}

# Read-only host diagnostics. This intentionally does not call `initialize` or
# create a probe volume: minimum versions plus Compose's stdin-only schema
# parse establish volume.subpath support without changing Docker state.
cmd_doctor () {
  [ "$#" -eq 0 ] || die "usage: aic doctor"
  local doctor_failures=0 doctor_warnings=0 node_raw node_version
  local context endpoint endpoint_path server_raw server_version
  local compose_raw compose_version compose_probe devcontainer_path devcontainer_version
  local git_root path_error identity_error

  printf 'aic doctor\n'

  if ! command -v node >/dev/null 2>&1; then
    doctor_fail "Node.js 18+ is required — install a current Node.js LTS release"
  else
    node_raw="$(node --version 2>/dev/null)" || node_raw=""
    node_version="$(diagnostic_version "$node_raw")"
    if [ -n "$node_version" ] && version_at_least "$node_version" 18.0.0; then
      doctor_ok "Node.js $node_version (minimum 18)"
    else
      doctor_fail "Node.js ${node_version:-unknown} is too old — install Node.js 18+"
    fi
  fi

  if ! command -v docker >/dev/null 2>&1; then
    doctor_fail "Docker CLI not found — install Docker Engine/Desktop"
  else
    context="$(docker context show 2>/dev/null)" || context="${DOCKER_CONTEXT:-default}"
    [ -n "$context" ] || context="default"
    endpoint=""
    if [ -n "${DOCKER_CONTEXT:-}" ]; then
      endpoint="$(docker context inspect "$DOCKER_CONTEXT" --format '{{(index .Endpoints "docker").Host}}' 2>/dev/null)" || endpoint=""
    elif [ -n "${DOCKER_HOST:-}" ]; then
      endpoint="$DOCKER_HOST"
    else
      endpoint="$(docker context inspect "$context" --format '{{(index .Endpoints "docker").Host}}' 2>/dev/null)" || endpoint=""
    fi

    if docker info >/dev/null 2>&1; then
      doctor_ok "Docker daemon reachable (context: $context)"
      server_raw="$(docker version --format '{{.Server.Version}}' 2>/dev/null)" || server_raw=""
      server_version="$(diagnostic_version "$server_raw")"
      if [ -n "$server_version" ] && version_at_least "$server_version" 25.0.0; then
        doctor_ok "Docker Engine $server_version (volume subpath minimum 25)"
      else
        doctor_fail "Docker Engine ${server_version:-unknown} lacks required volume subpath support — upgrade to 25+"
      fi
    else
      doctor_fail "Docker daemon is unreachable in context '$context' — start Docker or select a working context"
    fi

    case "$endpoint" in
      unix://*)
        endpoint_path="${endpoint#unix://}"
        if [ -S "$endpoint_path" ]; then
          doctor_ok "Docker context socket is available ($endpoint_path)"
          doctor_ok "managed helpers will bind the selected local socket"
        else
          doctor_fail "Docker context socket is missing ($endpoint_path) — fix the selected context"
        fi
        ;;
      '')
        doctor_warn "could not inspect the Docker context endpoint"
        [ -S /var/run/docker.sock ] \
          && doctor_ok "default managed helper socket /var/run/docker.sock is available" \
          || doctor_fail "no bind-mountable local Docker socket was found"
        ;;
      *)
        doctor_fail "selected Docker context is remote; aicontainer requires a local Unix-socket daemon for workspace and helper mounts"
        ;;
    esac

    compose_raw="$(docker compose version --short 2>/dev/null)" || compose_raw=""
    compose_version="$(diagnostic_version "$compose_raw")"
    if [ -n "$compose_version" ] && version_at_least "$compose_version" 2.24.0; then
      doctor_ok "Docker Compose $compose_version (minimum 2.24)"
    else
      doctor_fail "Docker Compose ${compose_version:-missing} is too old — install the Compose plugin 2.24+"
    fi
    compose_probe="$(docker compose -f - config --format json 2>/dev/null <<'YAML'
name: aic-doctor
services:
  probe:
    image: busybox
    volumes:
      - type: volume
        source: probe
        target: /probe
        volume:
          subpath: child
volumes:
  probe: {}
YAML
)" || compose_probe=""
    if [ -n "$compose_probe" ] && grep -q '"subpath"' <<< "$compose_probe"; then
      doctor_ok "Compose accepts volume.subpath (no Docker objects created)"
    else
      doctor_fail "Compose cannot resolve volume.subpath — upgrade Docker Compose to 2.24+"
    fi
  fi

  if [ -x "$AIC_HOME/node_modules/.bin/devcontainer" ]; then
    devcontainer_path="$AIC_HOME/node_modules/.bin/devcontainer"
  elif command -v devcontainer >/dev/null 2>&1; then
    devcontainer_path="$(command -v devcontainer)"
  else
    devcontainer_path=""
  fi
  if [ -n "$devcontainer_path" ]; then
    devcontainer_version="$("$devcontainer_path" --version 2>/dev/null | head -n1)" || devcontainer_version="unknown"
    doctor_ok "Dev Container CLI ${devcontainer_version:-unknown} ($devcontainer_path)"
  else
    doctor_fail "Dev Container CLI not found — install with: npm install -g @devcontainers/cli"
  fi

  if ! command -v git >/dev/null 2>&1; then
    doctor_fail "Git not found — install Git before creating an aicontainer project"
  elif git_root="$(git rev-parse --show-toplevel 2>/dev/null)"; then
    git_root="$(cd "$git_root" && pwd -P)"
    if [ "$git_root" = "$(pwd -P)" ]; then
      doctor_ok "Git project root is the current directory"
    else
      doctor_warn "current directory is below the Git root; run aic from $git_root"
    fi
    if [ -d .devcontainer ] && [ ! -d .git ]; then
      doctor_fail "this checkout does not expose .git as a directory; managed .git/config and hooks mounts require a conventional checkout"
    fi
  else
    doctor_warn "not in a Git project; cd to a project root before 'aic init'"
  fi

  if [ ! -f "$AIC_HOME/package.json" ] || [ ! -f "$TEMPLATE_DIR/devcontainer.json" ]; then
    doctor_fail "aic installation is incomplete at $AIC_HOME — reinstall aicontainer"
  else
    doctor_ok "aic installation and managed template are present"
  fi

  if [ ! -e .devcontainer ] && [ ! -L .devcontainer ]; then
    doctor_warn "this directory is not initialized; run 'aic init' from a Git project root"
  else
    path_error="$( (validate_devcontainer_paths optional) 2>&1)" || true
    if [ -n "$path_error" ]; then
      path_error="${path_error#aic: }"
      doctor_fail "managed path safety check failed: $path_error"
    elif [ ! -f .devcontainer/devcontainer.json ] || [ ! -f .devcontainer/docker-compose.yml ]; then
      doctor_fail ".devcontainer is incomplete — run 'aic init --force' after reviewing its contents"
    else
      doctor_ok "managed control paths are regular files/directories (no symlinks)"
      if export_runtime_environment >/dev/null 2>&1; then
        if [ ! -e .devcontainer/.env ]; then
          doctor_warn ".devcontainer/.env is absent; aic initialize will generate it before startup"
        elif validate_runtime_environment_file; then
          doctor_ok "managed Docker socket environment matches the selected context"
        else
          doctor_fail ".devcontainer/.env is stale or modified — run 'aic sync' or 'aic initialize'"
        fi
      fi
      if ! compose_has_project_name; then
        doctor_fail "legacy project identity blocks verified startup — run 'aic sync', then review the diff"
      elif command -v node >/dev/null 2>&1; then
        identity_error="$( (project_name >/dev/null) 2>&1)" || true
        if [ -n "$identity_error" ]; then
          identity_error="${identity_error#aic: }"
          doctor_fail "managed project identity is invalid: $identity_error"
        else
          doctor_ok "managed project identity matches this canonical path"
        fi
      fi
    fi
  fi

  if [ "$doctor_failures" -eq 0 ]; then
    if [ "$doctor_warnings" -gt 0 ]; then
      printf 'Result: ready with %s warning(s)\n' "$doctor_warnings"
    else
      printf 'Result: ready\n'
    fi
    return 0
  fi
  printf 'Result: %s blocker(s) found\n' "$doctor_failures"
  return 1
}

status_volume_state () {
  local name="$1"
  if ! docker volume inspect "$name" >/dev/null 2>&1; then
    printf 'absent'
  elif docker_volume_metadata_is_safe "$name"; then
    printf 'present'
  else
    printf 'UNSAFE metadata'
  fi
}

cmd_status () {
  [ "$#" -eq 0 ] || die "usage: aic status"
  require_in_project
  local project mode tools shell docker_mode consent="n/a" cli_version pinned image_summary
  local daemon=0 cid="" auth_cid="" runtime_state="unavailable" running_image=""
  local auth_state sessions_state bridge_state="unknown (Docker unavailable)" bridge_health=""
  local host_socket="unavailable" runtime_identity
  project="$(project_name)"
  mode="pull"; [ -f .devcontainer/Dockerfile ] && mode="build"
  tools="$(read_aic_tools)"; [ -n "$tools" ] || tools="claude-code,codex,opencode"
  shell="$(read_aic_shell)"; [ -n "$shell" ] || shell="$DEFAULT_SHELL"
  runtime_identity="$(runtime_user_id)"
  if host_socket="$(resolve_docker_socket 2>/dev/null)"; then :; else host_socket="unavailable"; fi
  docker_mode="$(read_compose_docker_mode)"
  case "$docker_mode" in
    none) docker_mode="none (ping/version only)" ;;
    ro) docker_consent_matches ro && consent="present" || consent="missing"; docker_mode="read-only (consent: $consent)" ;;
    rw) docker_consent_matches rw && consent="present" || consent="missing"; docker_mode="read-write (consent: $consent)" ;;
    *) docker_mode="invalid — run aic sync --no-docker" ;;
  esac

  cli_version="$(read_aic_version)"
  pinned="$(read_pinned_compose_version)"
  if [ "$mode" = "build" ]; then
    image_summary="local build (CLI v$cli_version)"
  elif [ -z "$pinned" ]; then
    image_summary="unrecognized pull image (CLI v$cli_version; run aic sync)"
  elif [ "$pinned" = "$cli_version" ]; then
    image_summary="pinned v$pinned (matches CLI)"
  else
    image_summary="pinned v$pinned (CLI v$cli_version; run aic sync && aic rebuild)"
  fi

  if command -v docker >/dev/null 2>&1 && docker info >/dev/null 2>&1; then
    daemon=1
    cid="$(docker ps -aq \
      --filter "label=com.docker.compose.project=$project" \
      --filter 'label=com.docker.compose.service=devcontainer' 2>/dev/null | head -n1)" || cid=""
    if [ -n "$cid" ]; then
      runtime_state="$(docker inspect --format '{{.State.Status}}' "$cid" 2>/dev/null)" || runtime_state="unknown"
      running_image="$(docker inspect --format '{{.Config.Image}}' "$cid" 2>/dev/null)" || running_image=""
    else
      runtime_state="not created"
    fi
    auth_cid="$(docker ps -aq \
      --filter "label=com.docker.compose.project=$project" \
      --filter 'label=com.docker.compose.service=aic-auth-sync' 2>/dev/null | head -n1)" || auth_cid=""
    if [ -z "$auth_cid" ]; then
      bridge_state="not created"
    else
      bridge_state="$(docker inspect --format '{{.State.Status}}' "$auth_cid" 2>/dev/null)" || bridge_state="unknown"
      bridge_health="$(docker inspect --format '{{if .State.Health}}{{.State.Health.Status}}{{end}}' "$auth_cid" 2>/dev/null)" || bridge_health=""
      case "$bridge_health" in
        healthy) bridge_state="healthy" ;;
        starting) bridge_state="starting" ;;
        unhealthy) bridge_state="UNHEALTHY" ;;
      esac
    fi
    auth_state="$(status_volume_state aic-auth-global)"
    sessions_state="$(status_volume_state "${project}_aic-sessions")"
  else
    auth_state="unknown (Docker unavailable)"
    sessions_state="unknown (Docker unavailable)"
  fi

  printf 'aic status\n'
  printf '  project:  %s\n' "$project"
  printf '  mode:     %s; tools: %s; shell: %s\n' "$mode" "$tools" "$shell"
  printf '  Docker:   %s\n' "$docker_mode"
  printf '  host:     socket %s; runtime uid:gid %s\n' "$host_socket" "$runtime_identity"
  printf '  image:    %s\n' "$image_summary"
  printf '  runtime:  %s' "$runtime_state"
  [ -n "$running_image" ] && printf ' (%s)' "$running_image"
  printf '\n'
  printf '  auth:     credential bridge %s\n' "$bridge_state"
  printf '  volumes:  auth %s; project sessions %s\n' "$auth_state" "$sessions_state"
  [ "$daemon" = "1" ] || printf '  hint:     start Docker to inspect runtime and volume state\n'
}

cmd_validate () {
  [ "$#" -eq 0 ] || die "usage: aic validate"
  require_in_project
  validate_project_security validate 0
  echo "aic: configuration valid — managed files and resolved Compose model are accepted."
}

cmd_upgrade () {
  check_for_update
  if [ -d "$AIC_HOME/.git" ]; then
    echo "aic: pulling latest aicontainer from $AIC_HOME"
    git -C "$AIC_HOME" pull --ff-only
  else
    echo "aic: installed via npm. Upgrade with:"
    echo "    npm update -g aicontainer"
    echo "aic: then in each project: 'aic sync' (re-pin compose to new version)"
    echo "aic: followed by 'aic rebuild' (pull the new image and recreate the container)"
  fi
}

cmd_version () {
  echo "aic v$(read_aic_version)"
  check_for_update
}

cmd_help () {
  cat <<'EOF'
aic — sandboxed devcontainer for running Claude Code + Codex + OpenCode in bypass mode

Usage:
  aic init [--build] [--force] [--docker-read|--docker|--no-docker] [--with TOOLS] [--shell SHELL]
                       Copy the aicontainer template into ./.devcontainer/.
                       Default: pull ghcr.io/stefanoginella/aicontainer:vX.Y.Z
                       where X.Y.Z is this aic's own version (pinned, not
                       :latest — `npm update -g aicontainer` + `aic sync`
                       is the upgrade path).
                       --build: full local build from template/Dockerfile (slow
                                first run, but you own the image).
                       Docker daemon access defaults to NONE (proxy ping/version
                       only; host containers/images/volumes stay hidden).
                       --docker-read: enable host Docker read APIs; this may
                                expose other containers' metadata, logs, and files.
                       --docker: enable READ-WRITE access (including POST/BUILD).
                                The agent can create privileged host containers
                                and siblings that dodge the firewall; use only
                                for testcontainers / in-container `docker compose`.
                       --no-docker: return to the secure NONE mode.
                       --with:  comma-separated tools to enable for this project
                                (claude-code, codex, opencode — any subset).
                                Defaults to an interactive checkbox prompt; all
                                three are selected by default. The choice is
                                stored as containerEnv.AIC_TOOLS in
                                devcontainer.json.
                       --shell: interactive shell — zsh (default, with oh-my-zsh
                                + powerlevel10k), bash, or fish. Defaults to an
                                interactive radio prompt. Stored as
                                containerEnv.AIC_SHELL; 'aic shell' and the
                                VS Code default terminal profile honor it.
  aic sync [--pull|--build] [--bump-base] [--docker-read|--docker|--no-docker] [--with TOOLS] [--shell SHELL]
                       Re-copy the aicontainer template files into an existing
                       ./.devcontainer/, overwriting them. Auto-detects the
                       mode from whether .devcontainer/Dockerfile exists; pass
                       --pull or --build to force one. Existing AIC_TOOLS /
                       AIC_SHELL selections and the Docker daemon exposure mode are
                       preserved unless overridden (--with / --shell /
                       --docker-read|--docker|--no-docker). Read/read-write modes
                       also require matching consent stored outside the repo, so
                       repository edits cannot grant Docker access themselves.
                       Project-owned files (Dockerfile.project, firewall-
                       allowlist, chown-paths, post-create.project.sh,
                       docker-compose.override.yml, vscode-extensions,
                       vscode-settings.json) are untouched; an existing
                       docker-compose.override.yml is auto-wired into
                       dockerComposeFile, and vscode-extensions /
                       vscode-settings.json are merged into the editor
                       customizations, so per-project tweaks survive the
                       sync. Useful after
                       editing template/ in a checkout — saves a manual cp -R.
                       Review with 'git diff' afterward.
                       --bump-base: if Dockerfile.project pins an explicit
                                FROM ghcr.io/stefanoginella/aicontainer:vX.Y.Z,
                                rewrite that tag to this aic's version without
                                prompting. (Without the flag, an interactive
                                sync warns about the drift and offers to bump;
                                non-interactive syncs just warn. :latest floats
                                and ARG-templated bases are left alone.)
  aic doctor           Check host prerequisites and project wiring without
                       creating containers, volumes, trust, or other state.
  aic status           Show this project's identity, selected tools/shell,
                       Docker exposure, image drift, runtime, and volume state.
  aic validate         Non-interactively validate managed files and the fully
                       resolved Compose model. Existing exact trust is honored;
                       this command never prompts or records trust.
  aic up [--allow-unsafe]
                       Pull/build and start the devcontainer for this project
                       (prints the trust boundary summary when it comes up)
                       Managed configuration and the fully resolved Compose
                       model are validated first. --allow-unsafe is a one-run
                       escape hatch for a reviewed host-access override.
  aic trust [--revoke] Review and persist approval for this project's exact
                       unsafe host-access configuration outside the repository.
                       Any relevant config change invalidates the approval.
  aic preflight        Print this project's trust boundary: what the agent can
                       read (mounts), what's blocked (.env/secrets), where
                       sessions persist, and whether outbound network is open
                       or firewalled. Read-only; also shown after 'aic up'.
  aic signing [ACTION] Set up commit signing inside the sandbox. The host's
                       signing key is never forwarded, so a host that signs
                       commits can't sign here without this. ACTION is one of:
                         status   (default) show the current signing state
                         auto     generate a sandbox-only ssh signing key
                                  (register its pubkey on GitHub as a Signing
                                  Key). --register adds it via gh for you
                                  (needs the write:ssh_signing_key scope).
                         byok     install a separate signing key you provide
                                  ('aic signing byok < your_key', or drop it in)
                         disable  turn commit signing off inside the sandbox
                       With no ACTION on a TTY, prints status then offers a
                       chooser. Mutating actions need the container up; the
                       choice persists in the aic-auth-global volume and takes
                       effect on the next 'aic rebuild'.
  aic shell            Open the configured interactive shell (AIC_SHELL) inside the devcontainer
  aic run CMD ...      Run CMD inside the devcontainer
  aic rebuild [--allow-unsafe]
                       Recreate the container from a fresh image
  aic down             Stop the container (volumes preserved)
  aic destroy [--yes]  Stop + remove container + per-project volumes
                       (global auth + shell history are preserved). Shows the
                       session-transcript volume size and confirms first (the
                       removal is irreversible); --yes / -y skips the prompt.
  aic upgrade          Update aic itself (git pull or 'npm update -g')
  aic completion SHELL Emit tab-completion script for bash, zsh, or fish.
                       Install (one-shot, recommended):
                         echo 'eval "$(aic completion zsh)"'  >> ~/.zshrc
                         echo 'eval "$(aic completion bash)"' >> ~/.bashrc
                         aic completion fish > ~/.config/fish/completions/aic.fish
  aic version          Print this aic's version (also: --version, -v)
  aic help             Show this help

Env:
  AIC_HOME             Where the aicontainer files live (default: this script's dir)
  AIC_NO_UPDATE_CHECK  Set to silence version notifications: the
                       'up'/'shell'/'rebuild' (and VS Code container-start)
                       drift warning (pinned image vs installed aic) and the
                       'version'/'upgrade' "newer aicontainer available" nudge.
  AIC_NO_OVERRIDE_SCAN Set to silence the legacy print-only raw scan of
                       project-owned docker-compose.override.yml /
                       Dockerfile.project. It does not bypass fail-closed
                       resolved-Compose validation; use aic trust or the
                       explicit one-run --allow-unsafe flag.
EOF
}

cmd_completion () {
  local shell="${1:-}"
  case "$shell" in
    bash) _completion_bash ;;
    zsh)  _completion_zsh  ;;
    fish) _completion_fish ;;
    "")   die "usage: aic completion <bash|zsh|fish>" ;;
    *)    die "unsupported shell: $shell (supported: bash, zsh, fish)" ;;
  esac
}

_completion_bash () {
  cat <<'BASH_EOF'
# aic bash completion. Install with:
#   echo 'eval "$(aic completion bash)"' >> ~/.bashrc
_aic_complete () {
  local cur prev cmd
  COMPREPLY=()
  cur="${COMP_WORDS[COMP_CWORD]}"
  prev="${COMP_WORDS[COMP_CWORD-1]}"

  local commands="init sync doctor status validate up trust preflight signing shell run rebuild down destroy upgrade completion version help"
  local tools="claude-code codex opencode claude-code,codex,opencode"
  local shells="zsh bash fish"

  if [ "$COMP_CWORD" -eq 1 ]; then
    COMPREPLY=( $(compgen -W "$commands" -- "$cur") )
    return
  fi

  cmd="${COMP_WORDS[1]}"
  case "$cmd" in
    init)
      case "$prev" in
        --with)  COMPREPLY=( $(compgen -W "$tools"  -- "$cur") ); return ;;
        --shell) COMPREPLY=( $(compgen -W "$shells" -- "$cur") ); return ;;
      esac
      COMPREPLY=( $(compgen -W "--build --force --docker-read --docker --no-docker --with --shell" -- "$cur") )
      ;;
    sync)
      case "$prev" in
        --with)  COMPREPLY=( $(compgen -W "$tools"  -- "$cur") ); return ;;
        --shell) COMPREPLY=( $(compgen -W "$shells" -- "$cur") ); return ;;
      esac
      COMPREPLY=( $(compgen -W "--pull --build --bump-base --docker-read --docker --no-docker --with --shell" -- "$cur") )
      ;;
    signing)
      COMPREPLY=( $(compgen -W "auto byok disable status --register" -- "$cur") )
      ;;
    up|rebuild)
      COMPREPLY=( $(compgen -W "--allow-unsafe" -- "$cur") )
      ;;
    trust)
      COMPREPLY=( $(compgen -W "--revoke" -- "$cur") )
      ;;
    destroy)
      COMPREPLY=( $(compgen -W "--yes" -- "$cur") )
      ;;
    completion)
      [ "$COMP_CWORD" -eq 2 ] && COMPREPLY=( $(compgen -W "bash zsh fish" -- "$cur") )
      ;;
  esac
}
complete -F _aic_complete aic
complete -F _aic_complete aicontainer
BASH_EOF
}

_completion_zsh () {
  cat <<'ZSH_EOF'
#compdef aic aicontainer
# aic zsh completion. Install with:
#   echo 'eval "$(aic completion zsh)"' >> ~/.zshrc
# Or save this output to a file named _aic in any directory on $fpath.
_aic () {
  local -a commands tools shells
  commands=(
    'init:Copy template into ./.devcontainer/'
    'sync:Re-copy template into existing ./.devcontainer/'
    'doctor:Check host prerequisites and project wiring (read-only)'
    'status:Show project configuration and runtime state'
    'validate:Validate the resolved configuration non-interactively'
    'up:Pull/build and start the devcontainer'
    'trust:Approve this exact host-access configuration outside the repository'
    'preflight:Print this project'\''s trust boundary (mounts, secrets, network, sessions)'
    'signing:Set up sandbox commit signing (auto/byok/disable/status)'
    'shell:Open an interactive shell inside the devcontainer'
    'run:Run a command inside the devcontainer'
    'rebuild:Recreate the container from a fresh image'
    'down:Stop the container (volumes preserved)'
    'destroy:Stop + remove container + per-project volumes'
    'upgrade:Update aic itself'
    'completion:Emit shell completion script'
    'version:Print this aic'\''s version'
    'help:Show help'
  )
  tools=('claude-code' 'codex' 'opencode' 'claude-code,codex,opencode')
  shells=('zsh' 'bash' 'fish')

  _arguments -C \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'aic command' commands
      ;;
    args)
      case $words[1] in
        init)
          _arguments \
            '--build[full local build from template/Dockerfile]' \
            '--force[overwrite existing .devcontainer/]' \
            '--docker-read[enable sensitive Docker metadata/log/file reads]' \
            '--docker[enable Docker socket write access (POST/BUILD)]' \
            '--no-docker[disable Docker object APIs (default)]' \
            '--with[comma-separated tools]:tools:('"${tools[*]}"')' \
            '--shell[interactive shell]:shell:('"${shells[*]}"')'
          ;;
        sync)
          _arguments \
            '--pull[force pull-mode template]' \
            '--build[force build-mode template]' \
            '--bump-base[bump Dockerfile.project FROM tag to this aic version]' \
            '--docker-read[enable sensitive Docker metadata/log/file reads]' \
            '--docker[enable Docker socket write access (POST/BUILD)]' \
            '--no-docker[disable Docker object APIs]' \
            '--with[comma-separated tools]:tools:('"${tools[*]}"')' \
            '--shell[interactive shell]:shell:('"${shells[*]}"')'
          ;;
        signing)
          _arguments \
            '--register[register the signing key on GitHub via gh]' \
            '1:action:(auto byok disable status)'
          ;;
        up|rebuild)
          _arguments '--allow-unsafe[allow reviewed unsafe host access for this run only]'
          ;;
        trust)
          _arguments '--revoke[remove this project'\''s stored host-access approval]'
          ;;
        destroy)
          _arguments '(--yes -y)'{--yes,-y}'[skip the confirmation prompt]'
          ;;
        completion)
          _values 'shell' bash zsh fish
          ;;
      esac
      ;;
  esac
}

# Bind the function whether this script is eval'd or autoloaded from $fpath.
compdef _aic aic aicontainer 2>/dev/null
ZSH_EOF
}

_completion_fish () {
  cat <<'FISH_EOF'
# aic fish completion. Install with:
#   aic completion fish > ~/.config/fish/completions/aic.fish
set -l aic_cmds init sync doctor status validate up trust preflight signing shell run rebuild down destroy upgrade completion version help

for cmd in aic aicontainer
  complete -c $cmd -f
  complete -c $cmd -n "not __fish_seen_subcommand_from $aic_cmds" -a init     -d 'Copy template into ./.devcontainer/'
  complete -c $cmd -n "not __fish_seen_subcommand_from $aic_cmds" -a sync     -d 'Re-copy template into existing ./.devcontainer/'
  complete -c $cmd -n "not __fish_seen_subcommand_from $aic_cmds" -a doctor   -d 'Check host prerequisites and project wiring'
  complete -c $cmd -n "not __fish_seen_subcommand_from $aic_cmds" -a status   -d 'Show project configuration and runtime state'
  complete -c $cmd -n "not __fish_seen_subcommand_from $aic_cmds" -a validate -d 'Validate the resolved configuration'
  complete -c $cmd -n "not __fish_seen_subcommand_from $aic_cmds" -a up       -d 'Start the devcontainer'
  complete -c $cmd -n "not __fish_seen_subcommand_from $aic_cmds" -a trust    -d 'Approve exact host-access configuration'
  complete -c $cmd -n "not __fish_seen_subcommand_from $aic_cmds" -a preflight -d 'Print this project\'s trust boundary (mounts, secrets, network)'
  complete -c $cmd -n "not __fish_seen_subcommand_from $aic_cmds" -a signing  -d 'Set up sandbox commit signing'
  complete -c $cmd -n "not __fish_seen_subcommand_from $aic_cmds" -a shell    -d 'Open the configured shell inside the devcontainer'
  complete -c $cmd -n "not __fish_seen_subcommand_from $aic_cmds" -a run      -d 'Run a command inside the devcontainer'
  complete -c $cmd -n "not __fish_seen_subcommand_from $aic_cmds" -a rebuild  -d 'Recreate the container from a fresh image'
  complete -c $cmd -n "not __fish_seen_subcommand_from $aic_cmds" -a down     -d 'Stop the container'
  complete -c $cmd -n "not __fish_seen_subcommand_from $aic_cmds" -a destroy  -d 'Stop + remove container + per-project volumes'
  complete -c $cmd -n "not __fish_seen_subcommand_from $aic_cmds" -a upgrade  -d 'Update aic itself'
  complete -c $cmd -n "not __fish_seen_subcommand_from $aic_cmds" -a completion -d 'Emit shell completion script'
  complete -c $cmd -n "not __fish_seen_subcommand_from $aic_cmds" -a version  -d 'Print this aic\'s version'
  complete -c $cmd -n "not __fish_seen_subcommand_from $aic_cmds" -a help     -d 'Show help'

  complete -c $cmd -n "__fish_seen_subcommand_from init" -l build -d 'full local build from template/Dockerfile'
  complete -c $cmd -n "__fish_seen_subcommand_from init" -l force -d 'overwrite existing .devcontainer/'
  complete -c $cmd -n "__fish_seen_subcommand_from init" -l docker-read -d 'enable sensitive Docker metadata/log/file reads'
  complete -c $cmd -n "__fish_seen_subcommand_from init" -l docker -d 'enable Docker socket write access (POST/BUILD)'
  complete -c $cmd -n "__fish_seen_subcommand_from init" -l no-docker -d 'disable Docker object APIs (default)'
  complete -c $cmd -n "__fish_seen_subcommand_from init" -l with  -d 'comma-separated tools' -xa 'claude-code codex opencode claude-code,codex,opencode'
  complete -c $cmd -n "__fish_seen_subcommand_from init" -l shell -d 'interactive shell' -xa 'zsh bash fish'

  complete -c $cmd -n "__fish_seen_subcommand_from sync" -l pull  -d 'force pull-mode template'
  complete -c $cmd -n "__fish_seen_subcommand_from sync" -l build -d 'force build-mode template'
  complete -c $cmd -n "__fish_seen_subcommand_from sync" -l bump-base -d 'bump Dockerfile.project FROM tag to this aic version'
  complete -c $cmd -n "__fish_seen_subcommand_from sync" -l docker-read -d 'enable sensitive Docker metadata/log/file reads'
  complete -c $cmd -n "__fish_seen_subcommand_from sync" -l docker -d 'enable Docker socket write access (POST/BUILD)'
  complete -c $cmd -n "__fish_seen_subcommand_from sync" -l no-docker -d 'disable Docker object APIs'
  complete -c $cmd -n "__fish_seen_subcommand_from sync" -l with  -d 'comma-separated tools' -xa 'claude-code codex opencode claude-code,codex,opencode'
  complete -c $cmd -n "__fish_seen_subcommand_from sync" -l shell -d 'interactive shell' -xa 'zsh bash fish'

  complete -c $cmd -n "__fish_seen_subcommand_from signing" -a 'auto byok disable status'
  complete -c $cmd -n "__fish_seen_subcommand_from signing" -l register -d 'register the signing key on GitHub via gh'

  complete -c $cmd -n "__fish_seen_subcommand_from up rebuild" -l allow-unsafe -d 'allow reviewed unsafe host access for this run only'
  complete -c $cmd -n "__fish_seen_subcommand_from trust" -l revoke -d 'remove stored host-access approval'

  complete -c $cmd -n "__fish_seen_subcommand_from destroy" -l yes -s y -d 'skip the confirmation prompt'

  complete -c $cmd -n "__fish_seen_subcommand_from completion" -a 'bash zsh fish'
end
FISH_EOF
}

case "${1:-help}" in
  init)    shift; cmd_init "$@" ;;
  sync)    shift; cmd_sync "$@" ;;
  doctor)  shift; cmd_doctor "$@" ;;
  status)  shift; cmd_status "$@" ;;
  validate) shift; cmd_validate "$@" ;;
  up)      shift; cmd_up "$@" ;;
  trust)   shift; cmd_trust "$@" ;;
  preflight) shift; cmd_preflight "$@" ;;
  check-drift) cmd_check_drift ;;   # internal: VS Code initializeCommand hook
  initialize) cmd_initialize ;;     # internal: trusted host initialize hook
  signing) shift; cmd_signing "$@" ;;
  shell)   shift; cmd_shell "$@" ;;
  run)     shift; cmd_run "$@" ;;
  rebuild) shift; cmd_rebuild "$@" ;;
  down)    shift; cmd_down "$@" ;;
  destroy) shift; cmd_destroy "$@" ;;
  upgrade) shift; cmd_upgrade "$@" ;;
  completion) shift; cmd_completion "$@" ;;
  version|-v|--version) cmd_version ;;
  help|-h|--help) cmd_help ;;
  *) err "unknown command: $1"; cmd_help; exit 1 ;;
esac
