#!/usr/bin/env bash
# =============================================================================
# aic — host-side CLI for aicontainer
# =============================================================================
# Thin shim around `@devcontainers/cli`. Resolves the aicontainer files
# relative to this script so both npm installs (npm install -g aicontainer)
# and git checkouts (~/.aicontainer + install.sh) work without configuration.
# Override with $AIC_HOME if you keep them somewhere unusual.
# =============================================================================
set -euo pipefail

# Resolve the real script directory, following symlinks (npm install -g
# creates one in the global bin dir). Works on macOS (BSD readlink, no -f)
# and Linux.
SCRIPT_PATH="${BASH_SOURCE[0]}"
while [ -L "$SCRIPT_PATH" ]; do
  link_dir="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
  SCRIPT_PATH="$(readlink "$SCRIPT_PATH")"
  [[ "$SCRIPT_PATH" != /* ]] && SCRIPT_PATH="$link_dir/$SCRIPT_PATH"
done
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"

AIC_HOME="${AIC_HOME:-$SCRIPT_DIR}"
TEMPLATE_DIR="$AIC_HOME/template"

err()  { echo "aic: $*" >&2; }
die()  { err "$*"; exit 1; }

# Prefer a devcontainer CLI bundled into our node_modules (when installed via
# `npm install -g aicontainer`), fall back to one on PATH (manual install).
resolve_devcontainer () {
  if [ -x "$AIC_HOME/node_modules/.bin/devcontainer" ]; then
    echo "$AIC_HOME/node_modules/.bin/devcontainer"
  elif command -v devcontainer >/dev/null 2>&1; then
    command -v devcontainer
  else
    die "devcontainer CLI not found. Install with: npm install -g @devcontainers/cli"
  fi
}

# Historical project name used before generated Compose files gained an
# explicit, path-unique top-level name. Keep it available so commands can still
# target projects that have not been synced yet.
legacy_project_name () {
  local base
  base="$(basename -- "$PWD")"
  base="$(printf '%s' "$base" | LC_ALL=C tr '[:upper:]' '[:lower:]' | LC_ALL=C tr -dc 'a-z0-9_-')"
  printf '%s_devcontainer\n' "$base"
}

# Deterministic Compose project name for newly generated configuration. The
# readable basename is suffixed with a hash of the canonical absolute project
# path, so two checkouts with the same basename never share containers or
# per-project session volumes.
expected_project_name () {
  local base root hash
  root="$(pwd -P)"
  base="$(basename -- "$root")"
  # toLowerCase().replace(/[^a-z0-9_-]/g, '') — strip, don't substitute. Keep
  # the readable portion bounded so Docker object names remain manageable.
  base="$(printf '%s' "$base" | LC_ALL=C tr '[:upper:]' '[:lower:]' | LC_ALL=C tr -dc 'a-z0-9_-')"
  base="${base:0:32}"
  [ -n "$base" ] || base="project"
  hash="$(node -e 'process.stdout.write(require("crypto").createHash("sha256").update(process.argv[1]).digest("hex").slice(0,12))' "$root")" \
    || die "Node.js 18+ is required to compute the project identity"
  printf 'aic-%s-%s\n' "$base" "$hash"
}

# The Dev Containers CLI remaps the vscode user to the host UID/GID on native
# Linux. Docker Desktop keeps the image's 1000:1000 identity. Sidecars that
# write the same named volumes must use that identity too, otherwise auth and
# session files become root-owned (or unwritable) after the first sync.
runtime_user_id () {
  local uid=1000 gid=1000
  if [ "$(uname -s 2>/dev/null || true)" = "Linux" ]; then
    local host_uid host_gid
    host_uid="$(id -u 2>/dev/null || true)"
    host_gid="$(id -g 2>/dev/null || true)"
    # Dev Containers deliberately does not remap vscode to root. Keep the image
    # identity when a Linux CI/host command itself runs as uid 0.
    if [[ "$host_uid" =~ ^[0-9]+$ ]] && [[ "$host_gid" =~ ^[0-9]+$ ]] \
       && [ "$host_uid" -gt 0 ]; then
      uid="$host_uid"; gid="$host_gid"
    fi
  fi
  printf '%s:%s\n' "$uid" "$gid"
}

# Return the active Docker context's local Unix socket. aicontainer needs a
# bind-mountable socket for its fixed ownership helper and socket proxy, so
# remote tcp/ssh contexts cannot provide the same boundary. AIC_DOCKER_SOCKET
# itself is never trusted from the environment or a repository .env file; it
# is always derived from Docker's selected context here.
resolve_docker_socket () {
  local endpoint="" context="" socket
  if [ -n "${DOCKER_CONTEXT:-}" ] && command -v docker >/dev/null 2>&1; then
    endpoint="$(docker context inspect "$DOCKER_CONTEXT" --format '{{(index .Endpoints "docker").Host}}' 2>/dev/null || true)"
  elif [ -n "${DOCKER_HOST:-}" ]; then
    endpoint="$DOCKER_HOST"
  elif command -v docker >/dev/null 2>&1; then
    context="$(docker context show 2>/dev/null || true)"
    [ -n "$context" ] || context="default"
    endpoint="$(docker context inspect "$context" --format '{{(index .Endpoints "docker").Host}}' 2>/dev/null || true)"
  fi
  [ -n "$endpoint" ] || endpoint="unix:///var/run/docker.sock"

  case "$endpoint" in
    unix:///*) socket="${endpoint#unix://}" ;;
    *) err "Docker context endpoint '$endpoint' is remote; aicontainer requires a local Unix-socket context"; return 1 ;;
  esac
  case "$socket" in
    /*) ;;
    *) err "Docker context returned a non-absolute Unix socket path: $socket"; return 1 ;;
  esac
  # Keep the generated dotenv line unambiguous and non-executable. These cover
  # standard Docker, Colima, OrbStack, rootless Docker, and Docker Desktop
  # paths; an exotic path gets an actionable failure rather than interpolation.
  case "$socket" in
    *[!A-Za-z0-9_./@%+-]*)
      err "Docker socket path contains unsupported characters: $socket"
      return 1
      ;;
  esac
  printf '%s\n' "$socket"
}

export_runtime_environment () {
  AIC_DOCKER_SOCKET="$(resolve_docker_socket)"
  AIC_RUNTIME_USER="$(runtime_user_id)"
  export AIC_DOCKER_SOCKET AIC_RUNTIME_USER
}

write_runtime_environment_file () {
  local file=".devcontainer/.env" tmp
  export_runtime_environment || die "could not select a bind-mountable Docker socket"
  [ -d .devcontainer ] || return 0
  if [ -L "$file" ] || { [ -e "$file" ] && [ ! -f "$file" ]; }; then
    die "$file must be a regular file, not a symlink"
  fi
  tmp="$(mktemp ".devcontainer/.aic-env.XXXXXX")"
  printf 'AIC_DOCKER_SOCKET=%s\nAIC_RUNTIME_USER=%s\n' \
    "$AIC_DOCKER_SOCKET" "$AIC_RUNTIME_USER" > "$tmp"
  chmod 600 "$tmp" 2>/dev/null || true
  mv -f "$tmp" "$file"
}

validate_runtime_environment_file () {
  local file=".devcontainer/.env" expected actual
  [ -e "$file" ] || return 0
  [ -f "$file" ] && [ ! -L "$file" ] || return 1
  expected="AIC_DOCKER_SOCKET=$AIC_DOCKER_SOCKET
AIC_RUNTIME_USER=$AIC_RUNTIME_USER"
  actual="$(cat "$file" 2>/dev/null || true)"
  [ "$actual" = "$expected" ]
}

# Resolve the name encoded by the current managed Compose file. Only accept the
# exact value aic computes for this path; a repository-controlled arbitrary
# `name:` must never make `aic down` / `destroy` target somebody else's stack.
# Old files without the managed name retain the legacy resolution until sync.
project_name () {
  local expected encoded=""
  expected="$(expected_project_name)"
  if [ -f .devcontainer/docker-compose.yml ] && [ ! -L .devcontainer/docker-compose.yml ]; then
    if ! grep -qE '^name[[:space:]]*:' .devcontainer/docker-compose.yml; then
      legacy_project_name
      return 0
    fi
    encoded="$(sed -n 's/^name[[:space:]]*:[[:space:]]*\([a-z0-9][a-z0-9_-]*\)[[:space:]]*$/\1/p' \
      .devcontainer/docker-compose.yml | head -n1)"
    [ "$encoded" = "$expected" ] || \
      die "managed Compose name is missing, malformed, or belongs to another path — run 'aic sync'"
    [ "$(grep -cE '^name[[:space:]]*:' .devcontainer/docker-compose.yml)" = "1" ] || \
      die "managed Compose file has multiple top-level names — run 'aic sync'"
    printf '%s\n' "$expected"
    return 0
  fi
  legacy_project_name
}

# True when the Compose file declares any top-level project name. A missing
# name identifies a pre-migration project; a present-but-wrong name is handled
# by project_name() and must never fall back to a basename that could target a
# different checkout.
compose_has_project_name () {
  [ -f .devcontainer/docker-compose.yml ] &&
    grep -qE '^name[[:space:]]*:' .devcontainer/docker-compose.yml
}

# Paths under .devcontainer are either aic-managed outputs or project-owned
# control inputs. Never follow a repository-provided symlink at this boundary:
# `aic init --force` / `aic sync` run as the host user, so following one could
# overwrite or read an arbitrary host file outside the repository.
AIC_CONTROL_FILES="devcontainer.json README.md docker-compose.yml .env .gitignore Dockerfile post-create.py aic-firewall aic-chown-volumes aic-lock-gitconfig .zshrc Dockerfile.project firewall-allowlist chown-paths post-create.project.sh docker-compose.override.yml vscode-extensions vscode-settings.json"

validate_devcontainer_paths () {
  local require_dir="${1:-optional}" path name linked
  if [ -L .devcontainer ]; then
    die ".devcontainer must be a real directory, not a symlink"
  fi
  if [ -e .devcontainer ] && [ ! -d .devcontainer ]; then
    die ".devcontainer exists but is not a directory"
  fi
  if [ "$require_dir" = "required" ] && [ ! -d .devcontainer ]; then
    die "no .devcontainer/ here — run 'aic init' first"
  fi
  [ -d .devcontainer ] || return 0

  for name in $AIC_CONTROL_FILES; do
    path=".devcontainer/$name"
    if [ -L "$path" ]; then
      die "$path must be a regular file, not a symlink"
    fi
    if [ -e "$path" ] && [ ! -f "$path" ]; then
      die "$path exists but is not a regular file"
    fi
  done

  path=".devcontainer/hooks"
  if [ -L "$path" ]; then
    die "$path must be a real directory, not a symlink"
  fi
  if [ -e "$path" ] && [ ! -d "$path" ]; then
    die "$path exists but is not a directory"
  fi
  if [ -d "$path" ]; then
    linked="$(find "$path" -type l -print -quit 2>/dev/null)"
    [ -z "$linked" ] || die "$linked is a symlink inside the managed hooks directory"
  fi
}

require_in_project () {
  validate_devcontainer_paths required
  [ -f .devcontainer/devcontainer.json ] || die "no .devcontainer/devcontainer.json here — run 'aic init' first"
}

# ---------------------------------------------------------------------------
# Per-project tool selection (claude-code, codex, opencode).
#
# Stored in .devcontainer/devcontainer.json as containerEnv.AIC_TOOLS, e.g.
# "claude-code,codex,opencode". post-create.py reads it to gate setup_claude /
# setup_codex / setup_opencode; the VSCode extensions array is filtered to match.
#
# Default for old projects without AIC_TOOLS (and for non-TTY init without
# --with) is all tools. Projects pinned with an explicit AIC_TOOLS keep it.
# ---------------------------------------------------------------------------
KNOWN_TOOLS="claude-code codex opencode"

# ---------------------------------------------------------------------------
# Per-project shell selection (zsh, bash, fish).
#
# Stored in .devcontainer/devcontainer.json as containerEnv.AIC_SHELL. The
# image bakes minimal configs for all three (history persistence + fnm).
# zsh keeps oh-my-zsh + powerlevel10k; bash and fish are barebones. We also
# patch terminal.integrated.defaultProfile.linux + fontFamily so the VS Code
# terminal opens in the chosen shell with a font that fits (MesloLGS NF for
# zsh's p10k icons, plain monospace otherwise).
# ---------------------------------------------------------------------------
KNOWN_SHELLS="zsh bash fish"
DEFAULT_SHELL="zsh"

validate_shell () {
  local raw="${1:-}"
  raw="$(printf '%s' "$raw" | tr -d '[:space:]')"
  [ -n "$raw" ] || die "no shell specified (valid: $KNOWN_SHELLS)"
  case "$raw" in
    zsh|bash|fish) echo "$raw" ;;
    *) die "unknown shell '$1' (valid: $KNOWN_SHELLS)" ;;
  esac
}

prompt_shell () {
  # Single-select radio menu on /dev/tty. Falls back to the default shell
  # when stdin isn't a TTY (CI, piped install).
  if ! (exec 3</dev/tty 4>/dev/tty) 2>/dev/null; then
    echo "$DEFAULT_SHELL"
    return
  fi

  local opts=("zsh" "bash" "fish")
  local descs=(
    "zsh + oh-my-zsh + powerlevel10k (default)"
    "bash (minimal, history + fnm)"
    "fish (minimal, history + fnm)"
  )
  local n=3 cur=0 i mark prefix

  exec 3</dev/tty 4>/dev/tty

  trap 'printf "\033[?25h" >&4 2>/dev/null; exec 3<&- 4>&- 2>/dev/null; trap - INT TERM EXIT; exit 130' INT TERM

  printf "Which shell should this project use?\n" >&4
  printf "(↑/↓ move · enter confirms · q cancels)\n\n" >&4
  printf "\033[?25l" >&4

  draw_shell_menu () {
    for i in 0 1 2; do
      if [ "$i" = "$cur" ]; then prefix="❯ "; mark="●"; else prefix="  "; mark="○"; fi
      printf "\033[K%s%s %-5s — %s\n" "$prefix" "$mark" "${opts[$i]}" "${descs[$i]}" >&4
    done
  }
  draw_shell_menu

  local k c1 c2
  while true; do
    IFS= read -rsn1 -u 3 k || k=""
    if [ "$k" = $'\033' ]; then
      IFS= read -rsn1 -u 3 c1 || c1=""
      IFS= read -rsn1 -u 3 c2 || c2=""
      if [ "$c1" = "[" ]; then
        [ "$c2" = "A" ] && cur=$(( (cur - 1 + n) % n ))
        [ "$c2" = "B" ] && cur=$(( (cur + 1) % n ))
      fi
    elif [ -z "$k" ]; then
      break
    elif [ "$k" = "q" ] || [ "$k" = "Q" ]; then
      printf "\n\033[?25h" >&4
      exec 3<&- 4>&-
      trap - INT TERM
      die "cancelled by user"
    fi
    printf "\033[%dA" "$n" >&4
    draw_shell_menu
  done

  printf "\033[?25h" >&4
  exec 3<&- 4>&-
  trap - INT TERM

  echo "${opts[$cur]}"
}

read_aic_shell () {
  # Read containerEnv.AIC_SHELL from .devcontainer/devcontainer.json.
  # Empty output if the field isn't set (older projects).
  local file=".devcontainer/devcontainer.json"
  [ -f "$file" ] || return 0
  sed -n 's/.*"AIC_SHELL"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' "$file" | head -n1
}

# Read this aic's own version from package.json. Used to pin the GHCR image
# tag in generated pull-mode compose files (so `aic@X.Y.Z` always pulls
# `ghcr.io/stefanoginella/aicontainer:vX.Y.Z`, never a floating :latest that
# could drift away from the CLI's filesystem expectations).
read_aic_version () {
  local pkg="$AIC_HOME/package.json"
  [ -f "$pkg" ] || die "package.json not found at $pkg (set AIC_HOME or reinstall aic)"
  local v
  v="$(sed -n 's/.*"version"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' "$pkg" | head -n1)"
  [ -n "$v" ] || die "could not read version from $pkg"
  echo "$v"
}

# --- Version drift / update notifications --------------------------------------
# Two distinct "am I current?" questions, answered by two cheap checks:
#   Tier 1 (warn_compose_drift): offline, local. Does this project's pinned image
#     tag match the aic CLI that's about to drive it? Catches the onset of the
#     common "npm update -g aicontainer, forgot to re-sync" drift.
#   Tier 2 (check_for_update): is a newer aicontainer published at all? Asks npm
#     (the install/upgrade source of truth — NOT GHCR, whose :latest floats on a
#     weekly cron independent of releases). Cached, fail-silent, opt-out.
# Both are best-effort and must never abort the command the user actually ran:
# every failure path returns 0, and version reads are guarded (read_aic_version
# dies on a broken install — fine off the hot path, fatal on it). Silence both
# with AIC_NO_UPDATE_CHECK=1.

is_semver () { [[ "$1" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; }

# 0 (true) iff $1 > $2 as a dotted numeric X.Y.Z. Defensive against junk fields.
version_gt () {
  local a="$1" b="$2" i ai bi
  local -a A B
  IFS=. read -ra A <<< "$a" || true
  IFS=. read -ra B <<< "$b" || true
  for i in 0 1 2; do
    ai="${A[i]:-0}"; ai="${ai//[!0-9]/}"; ai="${ai:-0}"
    bi="${B[i]:-0}"; bi="${bi//[!0-9]/}"; bi="${bi:-0}"
    ai=$((10#$ai)); bi=$((10#$bi))
    [ "$ai" -gt "$bi" ] && return 0
    [ "$ai" -lt "$bi" ] && return 1
  done
  return 1
}

# Echo X.Y.Z pinned into this project's compose image tag, or nothing. Anchored
# on the repo path so comment lines and the socket-proxy image never match, and
# build mode (no GHCR image: line — see docker-compose.build.yml) yields empty,
# which is how Tier 1 skips it: there's no version pin to compare against.
read_pinned_compose_version () {
  local f=".devcontainer/docker-compose.yml"
  [ -f "$f" ] || return 0
  sed -n 's|^[[:space:]]*image:[[:space:]]*ghcr\.io/stefanoginella/aicontainer:v\([0-9][0-9.]*\).*|\1|p' \
    "$f" | head -n1
}

# ---------------------------------------------------------------------------
# Docker daemon exposure (opt-in). The socket-proxy ships with object reads and
# writes disabled (only PING/VERSION remain available). `--docker-read` enables
# list/inspect APIs; `--docker` additionally enables POST/BUILD for projects
# that genuinely need testcontainers / in-container `docker compose`. The
# encoded choice survives sync, while matching consent lives outside the repo
# so a checkout cannot grant itself Docker visibility by editing Compose.
# ---------------------------------------------------------------------------
DEFAULT_DOCKER="none"

# Echo none|ro|rw for a coherent managed toggle set, "invalid" for a partial or
# malformed set, and nothing when there is no existing Compose file.
read_compose_docker_mode () {
  local f=".devcontainer/docker-compose.yml" key value reads=0 post build
  [ -f "$f" ] || return 0
  for key in CONTAINERS EVENTS IMAGES INFO NETWORKS VOLUMES; do
    value="$(sed -n "s/^[[:space:]]*${key}:[[:space:]]*\([01]\)[[:space:]]*\$/\1/p" "$f")"
    case "$value" in
      0) ;;
      1) reads=$((reads + 1)) ;;
      *) echo invalid; return 0 ;;
    esac
  done
  post="$(sed -n 's/^[[:space:]]*POST:[[:space:]]*\([01]\)[[:space:]]*$/\1/p' "$f")"
  build="$(sed -n 's/^[[:space:]]*BUILD:[[:space:]]*\([01]\)[[:space:]]*$/\1/p' "$f")"
  [ "$post" = "$build" ] || { echo invalid; return 0; }
  case "$reads:$post" in
    0:0) echo none ;;
    6:0) echo ro ;;
    6:1) echo rw ;;
    *)   echo invalid ;;
  esac
}

# Tier 1. Warn (to stderr, yellow on a TTY) when the project's pinned image tag
# and the installed aic disagree — the hot-path nudge for `aic up`/`aic shell`.
# Known blind spots, by design (offline + zero-cost beats full coverage here):
#   - It compares CLI-vs-pin, not pin-vs-running-container, so it can't see a
#     project that's synced but not yet rebuilt (pin == CLI, old container still
#     up). The remediation it prints — sync && rebuild — resolves that anyway.
#   - Build-mode projects have no version pin, so they're unguarded.
warn_compose_drift () {
  [ -n "${AIC_NO_UPDATE_CHECK:-}" ] && return 0
  local pinned cur
  pinned="$(read_pinned_compose_version 2>/dev/null)" || return 0
  [ -n "$pinned" ] || return 0
  cur="$(read_aic_version 2>/dev/null)" || return 0
  is_semver "$pinned" || return 0
  is_semver "$cur" || return 0
  [ "$pinned" = "$cur" ] && return 0

  local y rst
  if [ -t 2 ]; then y=$'\033[33m'; rst=$'\033[0m'; else y=""; rst=""; fi
  if version_gt "$cur" "$pinned"; then
    printf '%saic: this project pins the v%s image, but your installed aic is v%s.%s\n' \
      "$y" "$pinned" "$cur" "$rst" >&2
    printf '%saic: re-pin + refresh with: aic sync && aic rebuild%s\n' "$y" "$rst" >&2
  else
    printf '%saic: this project pins the v%s image, but your installed aic is older (v%s).%s\n' \
      "$y" "$pinned" "$cur" "$rst" >&2
    printf '%saic: upgrade aic (npm update -g aicontainer), or re-pin down with: aic sync && aic rebuild%s\n' \
      "$y" "$rst" >&2
  fi
  return 0
}

# Query the latest published version from the npm registry. Bounded + fail-silent
# (a slow/offline/firewalled host must never hang or error a version/upgrade
# call); curl primary so the timeout is portable, npm view as a fallback. The
# strict is_semver gate on the result is also the terminal-escape defense: a
# hostile/garbled registry response can't reach a printf.
fetch_latest_version () {
  local out=""
  if command -v curl >/dev/null 2>&1; then
    out="$(curl -fsS --max-time 3 https://registry.npmjs.org/aicontainer/latest 2>/dev/null \
      | grep -m1 -o '"version"[[:space:]]*:[[:space:]]*"[0-9][0-9.]*"' \
      | grep -m1 -o '[0-9][0-9.]*')" || out=""
  elif command -v npm >/dev/null 2>&1; then
    out="$(npm view aicontainer version 2>/dev/null)" || out=""
  fi
  is_semver "$out" && echo "$out"
}

# Tier 2. Nudge (to stderr) when a newer aicontainer is published. Result cached
# for 24h under $XDG_CACHE_HOME so it hits the network at most once a day; the CI
# skip keeps the workflow CLI tests offline. Confined to `aic version`/`aic
# upgrade` — deliberately off the `up`/`shell` hot path.
check_for_update () {
  [ -n "${AIC_NO_UPDATE_CHECK:-}" ] && return 0
  [ -n "${CI:-}" ] && return 0

  local cur; cur="$(read_aic_version 2>/dev/null)" || return 0
  is_semver "$cur" || return 0

  local now; now="$(date +%s 2>/dev/null)" || return 0
  case "$now" in ''|*[!0-9]*) return 0 ;; esac

  local dir="${XDG_CACHE_HOME:-$HOME/.cache}/aicontainer"
  local cache="$dir/update-check"
  local ts="" latest=""
  if [ -f "$cache" ]; then
    read -r ts latest < "$cache" 2>/dev/null || { ts=""; latest=""; }
  fi
  case "$ts" in ''|*[!0-9]*) ts=0 ;; esac

  if [ $((now - ts)) -ge 86400 ]; then
    local fetched; fetched="$(fetch_latest_version)"
    if is_semver "$fetched"; then
      latest="$fetched"
      mkdir -p "$dir" 2>/dev/null && printf '%s %s\n' "$now" "$latest" > "$cache" 2>/dev/null || true
    fi
    # Fetch failed: fall through on the (possibly stale) cached `latest`.
  fi

  is_semver "$latest" || return 0
  version_gt "$latest" "$cur" || return 0

  local y rst
  if [ -t 2 ]; then y=$'\033[33m'; rst=$'\033[0m'; else y=""; rst=""; fi
  printf '%saic: a newer aicontainer is available: v%s (you have v%s).%s\n' \
    "$y" "$latest" "$cur" "$rst" >&2
  if [ -d "$AIC_HOME/.git" ]; then
    printf '%saic: upgrade with: aic upgrade%s\n' "$y" "$rst" >&2
  else
    printf '%saic: upgrade with: npm update -g aicontainer%s\n' "$y" "$rst" >&2
  fi
  return 0
}
# ------------------------------------------------------------------------------

validate_tools () {
  # Normalize a user-supplied list ("codex,claude-code", "claude-code ,codex")
  # to canonical "claude-code,codex,opencode" order. Dies on unknown tools or
  # empty input.
  local raw="$1"
  raw="$(printf '%s' "$raw" | tr -d '[:space:]')"
  [ -n "$raw" ] || die "no tools selected (valid: $KNOWN_TOOLS)"
  local has_claude=0 has_codex=0 has_opencode=0
  case ",$raw," in *,claude-code,*) has_claude=1 ;; esac
  case ",$raw," in *,codex,*)       has_codex=1 ;; esac
  case ",$raw," in *,opencode,*)    has_opencode=1 ;; esac
  # Validate by elimination: strip known tokens and separators; anything left
  # is an unknown tool (avoids touching IFS or spawning a subshell).
  local rest="$raw"
  rest="${rest//claude-code/}"
  rest="${rest//codex/}"
  rest="${rest//opencode/}"
  rest="${rest//,/}"
  [ -z "$rest" ] || die "unknown tool(s) in '$1' (valid: $KNOWN_TOOLS)"
  local result=""
  [ "$has_claude" = "1" ]   && result="claude-code"
  [ "$has_codex"  = "1" ]   && result="${result:+$result,}codex"
  [ "$has_opencode" = "1" ] && result="${result:+$result,}opencode"
  [ -n "$result" ] || die "no tools selected (valid: $KNOWN_TOOLS)"
  echo "$result"
}

prompt_tools () {
  # Renders an interactive checkbox menu on /dev/tty and writes the
  # comma-separated selection to stdout. Falls back to both tools when
  # no controlling terminal is available (e.g. CI, piped install).
  # The probe-open is the only reliable check: /dev/tty exists as a device
  # node even in non-interactive contexts, but opening it fails. We probe
  # in a subshell so the test never leaves stale fds in the parent.
  if ! (exec 3</dev/tty 4>/dev/tty) 2>/dev/null; then
    echo "claude-code,codex,opencode"
    return
  fi

  local opts=("claude-code" "codex" "opencode")
  local sel=("1" "1" "1")
  local n=3 cur=0 i mark prefix

  exec 3</dev/tty 4>/dev/tty

  # Restore cursor + close fds on any exit path.
  trap 'printf "\033[?25h" >&4 2>/dev/null; exec 3<&- 4>&- 2>/dev/null; trap - INT TERM EXIT; exit 130' INT TERM

  printf "Which AI tools should this project use?\n" >&4
  printf "(↑/↓ move · space toggles · enter confirms · q cancels)\n\n" >&4
  printf "\033[?25l" >&4

  draw_tools_menu () {
    for ((i=0; i<n; i++)); do
      [ "${sel[$i]}" = "1" ] && mark="[✓]" || mark="[ ]"
      [ "$i" = "$cur" ] && prefix="❯ " || prefix="  "
      printf "\033[K%s%s %s\n" "$prefix" "$mark" "${opts[$i]}" >&4
    done
  }
  draw_tools_menu

  local k c1 c2 any
  while true; do
    IFS= read -rsn1 -u 3 k || k=""
    if [ "$k" = $'\033' ]; then
      IFS= read -rsn1 -u 3 c1 || c1=""
      IFS= read -rsn1 -u 3 c2 || c2=""
      if [ "$c1" = "[" ]; then
        [ "$c2" = "A" ] && cur=$(( (cur - 1 + n) % n ))
        [ "$c2" = "B" ] && cur=$(( (cur + 1) % n ))
      fi
    elif [ "$k" = " " ]; then
      if [ "${sel[$cur]}" = "1" ]; then sel[$cur]="0"; else sel[$cur]="1"; fi
    elif [ -z "$k" ]; then
      any=0
      for ((i=0; i<n; i++)); do [ "${sel[$i]}" = "1" ] && any=1; done
      if [ "$any" = "1" ]; then break; fi
    elif [ "$k" = "q" ] || [ "$k" = "Q" ]; then
      printf "\n\033[?25h" >&4
      exec 3<&- 4>&-
      trap - INT TERM
      die "cancelled by user"
    fi
    printf "\033[%dA" "$n" >&4
    draw_tools_menu
  done

  printf "\033[?25h" >&4
  exec 3<&- 4>&-
  trap - INT TERM

  local result=""
  for ((i=0; i<n; i++)); do
    [ "${sel[$i]}" = "1" ] && result="${result:+$result,}${opts[$i]}"
  done
  echo "$result"
}

read_aic_tools () {
  # Read containerEnv.AIC_TOOLS from .devcontainer/devcontainer.json.
  # Empty output if the field isn't set (older projects).
  local file=".devcontainer/devcontainer.json"
  [ -f "$file" ] || return 0
  sed -n 's/.*"AIC_TOOLS"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' "$file" | head -n1
}

# Build the injection block for project-owned VS Code extensions. Reads the
# given file (if present): skips blank/# lines, trims surrounding whitespace,
# validates each remaining line against the publisher.extension id grammar and
# warns+skips anything else (so a stray line can't smuggle arbitrary JSON into
# devcontainer.json), dedups, and emits one leading-comma line per id. Leading
# commas keep the result valid JSON no matter how the template array ends.
# Echoes the (possibly empty) block; warnings go to stderr.
build_vscode_ext_block () {
  local file="$1" line id block="" seen=","
  [ -f "$file" ] || return 0
  while IFS= read -r line || [ -n "$line" ]; do
    id="$(printf '%s' "$line" | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//')"
    case "$id" in ''|\#*) continue ;; esac
    if ! printf '%s' "$id" | grep -Eq '^[A-Za-z0-9][A-Za-z0-9._-]*\.[A-Za-z0-9._-]+$'; then
      printf 'aic: ignoring invalid vscode-extensions entry: %s\n' "$id" >&2
      continue
    fi
    case "$seen" in *",$id,"*) continue ;; esac
    seen="$seen$id,"
    block="$block        ,\"$id\"
"
  done < "$file"
  printf '%s' "$block"
}

# Build the injection block for project-owned VS Code settings. The input is
# strict JSON (not JSONC), must be a non-array object, and is parsed then
# serialized by Node. Never splice user-controlled text between braces: a
# malformed object could otherwise escape customizations.vscode.settings and
# inject host-facing top-level devcontainer properties.
build_vscode_settings_block () {
  local file="$1" output
  [ -f "$file" ] || return 0
  if ! output="$(node -e '
    const fs = require("fs");
    const file = process.argv[1], templateFile = process.argv[2];
    let value;
    try {
      value = JSON.parse(fs.readFileSync(file, "utf8"));
    } catch (_) {
      process.exit(2);
    }
    if (value === null || Array.isArray(value) || typeof value !== "object") {
      process.exit(3);
    }

    // Project settings are appended at the managed marker. Duplicate JSON
    // keys are accepted by VS Code with the last value winning, so filter all
    // top-level keys owned by aic before serialization. Derive the set from
    // the installed template to keep this rule aligned as managed settings
    // evolve.
    const template = fs.readFileSync(templateFile, "utf8");
    const marker = template.indexOf("// aic:vscode-settings");
    const start = template.lastIndexOf("\"settings\": {", marker);
    if (marker < 0 || start < 0) process.exit(4);
    const managedBlock = template.slice(start, marker);
    const managedKeys = new Set();
    const keyPattern = /^        ("(?:[^"\\]|\\.)+")\s*:/gm;
    let match;
    while ((match = keyPattern.exec(managedBlock)) !== null) {
      managedKeys.add(JSON.parse(match[1]));
    }
    for (const key of Object.keys(value)) {
      if (!managedKeys.has(key)) continue;
      process.stderr.write(`aic: ignoring vscode-settings.json key managed by aic: ${key}\n`);
      delete value[key];
    }

    const entries = Object.entries(value);
    if (!entries.length) process.exit(0);
    const lines = JSON.stringify(value, null, 2).split("\n").slice(1, -1);
    lines[0] = "," + lines[0].trimStart();
    process.stdout.write(lines.map(line => "        " + line).join("\n"));
  ' "$file" "$TEMPLATE_DIR/devcontainer.json")"; then
    printf 'aic: ignoring vscode-settings.json (must be a strict JSON object)\n' >&2
    return 0
  fi
  printf '%s' "$output"
}

patch_devcontainer_json () {
  # Patch the freshly-copied devcontainer.json:
  #   1. Inject "AIC_TOOLS" and "AIC_SHELL" inside containerEnv.
  #   2. Drop "anthropic.claude-code" extension when claude-code not selected.
  #   3. Drop "openai.chatgpt" extension when codex not selected.
  #      (and "sst-dev.opencode" when opencode not selected.)
  #   4. Patch terminal.integrated.defaultProfile.linux to the chosen shell.
  #   5. Patch terminal.integrated.fontFamily — MesloLGS NF for zsh (p10k icons),
  #      plain monospace for bash/fish (no nerd font required on the host).
  #   6. Wire a project-owned docker-compose.override.yml into dockerComposeFile
  #      when one exists, so per-project compose tweaks (containerEnv-equivalent
  #      `environment:`, extra_hosts, build.dockerfile) survive `aic sync`. The
  #      override file itself is never copied or overwritten by apply_template;
  #      this only re-applies the reference, which the template ships without.
  #   7. Rewrite "name" to "<project folder>-aicontainer" so each project shows a
  #      distinct label in VS Code's remote indicator. Re-derived from $PWD every
  #      run (like AIC_TOOLS/AIC_SHELL), so it's recomputed on each init/sync and
  #      the template can keep the bare "aicontainer" placeholder.
  #   8. Merge project-owned .devcontainer/vscode-extensions (one extension id
  #      per line) into customizations.vscode.extensions at the
  #      "// aic:vscode-extensions" marker.
  #   9. Merge project-owned .devcontainer/vscode-settings.json (a JSON object)
  #      into customizations.vscode.settings at the "// aic:vscode-settings"
  #      marker.
  #      Both (8) and (9) are opt-in by file presence, never copied/overwritten
  #      by apply_template, and RO inside the container — same contract as
  #      firewall-allowlist / chown-paths. Injected blocks are leading-comma
  #      so they stay valid JSON regardless of how the template array/object
  #      ends; the source files are read fresh each run from the pristine
  #      template, so re-injection is idempotent across syncs.
  # Operates line-wise so JSONC comments don't trip us up.
  local file="$1" tools="$2" shell="$3"
  local hc=0 hx=0 hoc=0 ov=0 tmp font dir pname cname
  local ext_block="" settings_block=""
  case ",$tools," in *,claude-code,*) hc=1 ;; esac
  case ",$tools," in *,codex,*)       hx=1 ;; esac
  case ",$tools," in *,opencode,*)    hoc=1 ;; esac

  dir="$(dirname "$file")"
  [ -f "$dir/docker-compose.override.yml" ] && ov=1
  ext_block="$(build_vscode_ext_block "$dir/vscode-extensions")"
  settings_block="$(build_vscode_settings_block "$dir/vscode-settings.json")"

  # Project label from the cwd (project root for both init and sync). JSON-escape
  # backslashes and double-quotes so an odd folder name still yields valid JSON.
  pname="$(basename "$PWD")"
  pname="${pname//\\/\\\\}"
  pname="${pname//\"/\\\"}"
  cname="$pname-aicontainer"

  case "$shell" in
    zsh) font="'MesloLGS NF', monospace" ;;
    *)   font="monospace" ;;
  esac

  tmp="$(mktemp "${file}.XXXXXX")"
  AIC_DEVCONTAINER_NAME="$cname" \
  AIC_VSCODE_EXT_BLOCK="$ext_block" \
  AIC_VSCODE_SETTINGS_BLOCK="$settings_block" \
  awk -v tools="$tools" -v shell="$shell" -v font="$font" -v hc="$hc" -v hx="$hx" -v hoc="$hoc" -v ov="$ov" '
    {
      # Rewrite the top-level "name" to the per-project label. Read from ENVIRON
      # (not -v) so awk does not re-interpret backslashes in the folder name.
      if ($0 ~ /^[[:space:]]*"name"[[:space:]]*:/) {
        print "  \"name\": \"" ENVIRON["AIC_DEVCONTAINER_NAME"] "\","
        next
      }

      # Merge project-owned extensions / settings just before their markers.
      # The blocks are built leading-comma (ENVIRON, so backslashes/quotes in
      # settings values survive) and empty when the source file is absent.
      if ($0 ~ /aic:vscode-extensions/) {
        if (ENVIRON["AIC_VSCODE_EXT_BLOCK"] != "") printf "%s\n", ENVIRON["AIC_VSCODE_EXT_BLOCK"]
        print
        next
      }
      if ($0 ~ /aic:vscode-settings/) {
        if (ENVIRON["AIC_VSCODE_SETTINGS_BLOCK"] != "") printf "%s\n", ENVIRON["AIC_VSCODE_SETTINGS_BLOCK"]
        print
        next
      }

      if ($0 ~ /^[[:space:]]*"anthropic\.claude-code",[[:space:]]*$/ && hc == 0) next
      if ($0 ~ /^[[:space:]]*"openai\.chatgpt",[[:space:]]*$/        && hx == 0) next
      if ($0 ~ /^[[:space:]]*"sst-dev\.opencode",[[:space:]]*$/      && hoc == 0) next

      # Per-shell terminal defaults (only act on the relevant lines so
      # generic "zsh" tokens elsewhere in the file are untouched).
      if ($0 ~ /"terminal\.integrated\.defaultProfile\.linux"/) {
        sub(/"zsh"/, "\"" shell "\"")
      }
      if ($0 ~ /"terminal\.integrated\.fontFamily"/) {
        sub(/:[[:space:]]*"[^"]*"/, ": \"" font "\"")
      }

      # Append the override to the dockerComposeFile array. Docker Compose
      # merges files left-to-right, so the override wins. Guarded so a file
      # that already lists it (or a hand-edited multi-entry array) is a no-op.
      if (ov == 1 && $0 ~ /"dockerComposeFile"/ && $0 !~ /docker-compose\.override\.yml/) {
        sub(/\]/, ", \"docker-compose.override.yml\"]")
      }

      print
      if ($0 ~ /^[[:space:]]*"containerEnv":[[:space:]]*\{[[:space:]]*$/) {
        print "    \"AIC_TOOLS\": \"" tools "\","
        print "    \"AIC_SHELL\": \"" shell "\","
      }
    }
  ' "$file" > "$tmp" && mv "$tmp" "$file"
}

# Apply all socket-proxy read/write toggles in the freshly-copied Compose file.
# none=ping/version only, ro=list/inspect, rw=list/inspect + POST/BUILD.
apply_docker_mode () {
  local file="$1" docker="$2" read write tmp
  [ -f "$file" ] || return 0
  case "$docker" in
    none) read=0; write=0 ;;
    ro)   read=1; write=0 ;;
    rw)   read=1; write=1 ;;
    *)    die "internal error: unknown Docker exposure mode '$docker'" ;;
  esac
  tmp="$(mktemp "${file}.XXXXXX")"
  sed -E "s/^([[:space:]]*)(CONTAINERS|EVENTS|IMAGES|INFO|NETWORKS|VOLUMES):[[:space:]]*[01][[:space:]]*\$/\1\2: ${read}/; \
          s/^([[:space:]]*)POST:[[:space:]]*[01][[:space:]]*\$/\1POST: ${write}/; \
          s/^([[:space:]]*)BUILD:[[:space:]]*[01][[:space:]]*\$/\1BUILD: ${write}/" \
    "$file" > "$tmp" && mv "$tmp" "$file"
}

# Copy a managed file through a sibling temporary and rename it into place.
# The final rename replaces a destination symlink itself instead of following
# it; validate_devcontainer_paths rejects such links first as a clearer error.
atomic_copy_file () {
  local src="$1" dst="$2" tmp
  [ -f "$src" ] && [ ! -L "$src" ] || die "managed template file is missing or unsafe: $src"
  tmp="$(mktemp "$(dirname "$dst")/.aic-$(basename "$dst").XXXXXX")"
  if cp -p "$src" "$tmp" && mv -f "$tmp" "$dst"; then
    return 0
  fi
  rm -f "$tmp"
  die "could not install managed file: $dst"
}

# Stage the managed hooks tree before replacing it, so a partial recursive copy
# can never become the live tree. Symlinks are forbidden in both source and
# destination because hooks execute security-sensitive host/container logic.
atomic_copy_hooks () {
  local src="$1" dst="$2" parent tmp linked
  [ -d "$src" ] && [ ! -L "$src" ] || die "managed hooks template is missing or unsafe: $src"
  linked="$(find "$src" -type l -print -quit 2>/dev/null)"
  [ -z "$linked" ] || die "managed hooks template contains a symlink: $linked"
  parent="$(dirname "$dst")"
  tmp="$(mktemp -d "$parent/.aic-hooks.XXXXXX")"
  if ! cp -Rp "$src/." "$tmp/"; then
    rm -rf "$tmp"
    die "could not stage managed hooks"
  fi
  rm -rf "$dst"
  if ! mv "$tmp" "$dst"; then
    rm -rf "$tmp"
    die "could not install managed hooks"
  fi
}

# Replace the literal template placeholder with the deterministic per-path
# Compose project name. This keeps devcontainer CLI, direct Compose commands,
# and per-project volume names aligned.
apply_project_name () {
  local file="$1" name tmp
  name="$(expected_project_name)"
  grep -qE '^name:[[:space:]]*aic-project[[:space:]]*$' "$file" \
    || die "managed compose template is missing top-level 'name: aic-project'"
  tmp="$(mktemp "${file}.XXXXXX")"
  sed -E "s/^name:[[:space:]]*aic-project[[:space:]]*\$/name: ${name}/" "$file" > "$tmp" \
    && mv "$tmp" "$file"
}

# Verify the managed Compose identity anchor. Its value is interpolated from
# the gitignored host runtime file instead of rewriting tracked Compose on each
# machine; that keeps mixed macOS/Linux teams free of UID-only diffs.
apply_runtime_user () {
  local file="$1"
  grep -Fqx 'x-aic-runtime-user: &aic-runtime-user "${AIC_RUNTIME_USER:-1000:1000}"' "$file" \
    || die "managed compose template is missing x-aic-runtime-user interpolation"
}

# Copy template files into .devcontainer/, picking the right compose variant
# for $mode (pull or build) and only the files that mode needs. Idempotent:
# overwrites any existing target files; safe to call from init or sync.
apply_template () {
  local mode="$1" src="$2" dst="$3" docker="${4:-$DEFAULT_DOCKER}"
  [ -d "$src" ] || die "template not found at $src (set AIC_HOME or reinstall aic)"
  validate_devcontainer_paths optional
  mkdir -p "$dst"

  atomic_copy_file "$src/devcontainer.json" "$dst/devcontainer.json"
  # Copied in both modes: an in-repo guide to which .devcontainer/ files are
  # aic-managed (overwritten on sync) vs project-owned (survive). Steers humans
  # and AI agents away from hand-editing devcontainer.json. Itself aic-managed.
  atomic_copy_file "$src/README.md" "$dst/README.md"
  atomic_copy_file "$src/.gitignore" "$dst/.gitignore"
  case "$mode" in
    pull)
      atomic_copy_file "$src/docker-compose.pull.yml" "$dst/docker-compose.yml"
      # Pin the image tag to this aic's version so the CLI and the container
      # FS layout (hooks, sudoers, helper scripts) can't drift apart. Template
      # ships `:latest` as the canonical placeholder; we rewrite at copy time.
      local ver tmp
      ver="$(read_aic_version)"
      tmp="$(mktemp "$dst/docker-compose.yml.XXXXXX")"
      sed "s|ghcr.io/stefanoginella/aicontainer:latest|ghcr.io/stefanoginella/aicontainer:v${ver}|g" \
        "$dst/docker-compose.yml" > "$tmp" && mv "$tmp" "$dst/docker-compose.yml"
      # Pull mode must remove every managed build-mode artifact. Leaving the
      # old Dockerfile behind makes the next plain `aic sync` auto-detect build
      # mode and silently flip the project back.
      rm -f "$dst/Dockerfile" "$dst/post-create.py" "$dst/aic-firewall" \
        "$dst/aic-chown-volumes" "$dst/aic-lock-gitconfig" "$dst/.zshrc"
      rm -rf "$dst/hooks"
      ;;
    build)
      atomic_copy_file "$src/docker-compose.build.yml" "$dst/docker-compose.yml"
      atomic_copy_file "$src/Dockerfile"         "$dst/Dockerfile"
      atomic_copy_file "$src/post-create.py"     "$dst/post-create.py"
      atomic_copy_file "$src/aic-firewall"       "$dst/aic-firewall"
      atomic_copy_file "$src/aic-chown-volumes"  "$dst/aic-chown-volumes"
      atomic_copy_file "$src/aic-lock-gitconfig" "$dst/aic-lock-gitconfig"
      atomic_copy_file "$src/.zshrc"             "$dst/.zshrc"
      atomic_copy_hooks "$src/hooks"              "$dst/hooks"
      ;;
    *) die "internal error: unknown mode '$mode'" ;;
  esac
  apply_project_name "$dst/docker-compose.yml"
  apply_runtime_user "$dst/docker-compose.yml"
  # Apply the project's Docker daemon exposure mode to the copied compose file.
  apply_docker_mode "$dst/docker-compose.yml" "$docker"
  # Direct VS Code starts do not inherit exports from the host initialize hook,
  # so leave Compose a tiny gitignored file containing the selected local
  # Docker context's socket path. `aic initialize` refreshes it on every start.
  write_runtime_environment_file
}

cmd_init () {
  local mode="pull" force="" tools="" shell="" docker="$DEFAULT_DOCKER"
  validate_devcontainer_paths optional
  while [ $# -gt 0 ]; do
    case "$1" in
      --build) mode="build" ;;
      --force) force="1" ;;
      --with)  shift; tools="${1:-}" ;;
      --with=*) tools="${1#--with=}" ;;
      --shell) shift; shell="${1:-}" ;;
      --shell=*) shell="${1#--shell=}" ;;
      --docker-read) docker="ro" ;;
      --docker) docker="rw" ;;
      --no-docker) docker="none" ;;
      *) die "unknown init flag: $1 (try --build, --force, --docker-read, --docker, --with claude-code,codex,opencode, or --shell zsh|bash|fish)" ;;
    esac
    shift
  done

  if [ -e .devcontainer ] && [ -z "$force" ]; then
    die ".devcontainer/ already exists. Re-run with --force to overwrite."
  fi

  if [ -z "$tools" ]; then
    tools="$(prompt_tools)"
  fi
  tools="$(validate_tools "$tools")"

  if [ -z "$shell" ]; then
    shell="$(prompt_shell)"
  fi
  shell="$(validate_shell "$shell")"

  resolve_docker_socket >/dev/null || die "cannot initialize aicontainer with the selected Docker context"
  apply_template "$mode" "$TEMPLATE_DIR" ".devcontainer" "$docker"
  patch_devcontainer_json ".devcontainer/devcontainer.json" "$tools" "$shell"
  set_docker_consent "$docker"
  echo "aic: copied $mode-mode template into .devcontainer/ (tools: $tools, shell: $shell, docker: $docker)"
  case "$docker" in
    ro) echo "aic: Docker daemon READ access ENABLED — host Docker APIs may expose container metadata, logs, and files." ;;
    rw) echo "aic: Docker daemon READ-WRITE access ENABLED — the agent can create/build containers on the host daemon." ;;
  esac
  [ -f .devcontainer/docker-compose.override.yml ] && \
    echo "aic: wired existing docker-compose.override.yml into dockerComposeFile"
  if [ "$mode" = "pull" ]; then
    local ver; ver="$(read_aic_version)"
    echo "aic: 'aic up' will pull ghcr.io/stefanoginella/aicontainer:v${ver} (pinned to this aic's version)"
  else
    echo "aic: 'aic up' will build the image locally from .devcontainer/Dockerfile"
  fi
  echo "aic: next: 'aic up' then 'aic shell'"
}

# A project's Dockerfile.project is project-owned, so `aic sync` never rewrites
# it — but if it pins the aicontainer base to an explicit
# `FROM ghcr.io/stefanoginella/aicontainer:vX.Y.Z`, that tag silently lags the
# version this aic pins into docker-compose.yml after `npm update -g
# aicontainer`. And when an override's build: block points at Dockerfile.project,
# that stale FROM is what actually runs (the compose `image:` pin is bypassed),
# so the container can come up on an old base with none of the new behavior.
# Warn on that drift; rewrite it in place only when --bump-base is given, and
# only for a literal version pin — never :latest floats, ARG-templated bases,
# or other repos (those are deliberate, so we leave them alone).
check_dockerfile_project_base () {
  local ver="$1" do_bump="$2"
  local df=".devcontainer/Dockerfile.project"
  [ -f "$df" ] || return 0

  local repo="ghcr.io/stefanoginella/aicontainer"
  local cur_tag
  cur_tag="$(sed -n "s|^[[:space:]]*FROM[[:space:]]\{1,\}${repo}:\([A-Za-z0-9._-]\{1,\}\).*|\1|p" "$df" | head -n1)"
  [ -n "$cur_tag" ] || return 0          # no literal FROM <repo>:tag — templated, other repo, or absent

  local want="v${ver}"
  [ "$cur_tag" = "$want" ] && return 0    # already matches the pinned version

  if [ "$cur_tag" = "latest" ]; then
    echo "aic: note: Dockerfile.project tracks ${repo}:latest (floating base); not pinning it to :${want}" >&2
    return 0
  fi

  # Drift detected. With --bump-base we rewrite in place unconditionally.
  # Otherwise warn (yellow on a TTY) and, when stdin is interactive, offer to
  # bump now (default Yes). Non-interactive callers (CI, piped) are never
  # prompted: they get the command hint and the file is left untouched —
  # preserving the "plain sync only warns" contract the CLI tests guard.
  if [ -z "$do_bump" ]; then
    local y rst
    if [ -t 2 ]; then y=$'\033[33m'; rst=$'\033[0m'; else y=""; rst=""; fi
    printf "%saic: warning: Dockerfile.project pins %s:%s, but this aic pins :%s.%s\n" \
      "$y" "$repo" "$cur_tag" "$want" "$rst" >&2

    if [ -t 0 ]; then
      local reply
      printf "%saic: bump its FROM to :%s now? [Y/n]%s " "$y" "$want" "$rst" >&2
      IFS= read -r reply || reply=""
      case "$reply" in
        n|N|no|NO)
          echo "aic:          left as-is — bump later with 'aic sync --bump-base'." >&2
          return 0
          ;;
      esac
      do_bump=1
    else
      echo "aic:          Bump its FROM to match, or re-run 'aic sync --bump-base' to do it for you." >&2
      return 0
    fi
  fi

  # Escape dots for the sed LHS; anchor on the full repo path so the swap
  # can't hit an unrelated token. Replaces every occurrence (multi-stage
  # FROMs / an ARG default all reference the same base).
  local re_repo="${repo//./\\.}" re_tag="${cur_tag//./\\.}" tmp
  tmp="$(mktemp "${df}.XXXXXX")"
  sed "s|${re_repo}:${re_tag}|${repo}:${want}|g" "$df" > "$tmp" && mv "$tmp" "$df"
  echo "aic: bumped Dockerfile.project base → ${repo}:${want} (was :${cur_tag})"
}

cmd_sync () {
  require_in_project
  local mode="" tools="" shell="" bump_base="" docker="" docker_explicit=0 was_legacy=0
  # A missing top-level name is the only legacy form. A present but tampered
  # name is simply overwritten from the trusted template; never resolve it as
  # the old basename-scoped identity.
  compose_has_project_name || was_legacy=1
  while [ $# -gt 0 ]; do
    case "$1" in
      --pull)  mode="pull" ;;
      --build) mode="build" ;;
      --with)  shift; tools="${1:-}" ;;
      --with=*) tools="${1#--with=}" ;;
      --shell) shift; shell="${1:-}" ;;
      --shell=*) shell="${1#--shell=}" ;;
      --bump-base) bump_base="1" ;;
      --docker-read) docker="ro"; docker_explicit=1 ;;
      --docker) docker="rw"; docker_explicit=1 ;;
      --no-docker) docker="none"; docker_explicit=1 ;;
      *) die "unknown sync flag: $1 (try --pull, --build, --bump-base, --docker-read, --docker, --with claude-code,codex,opencode, or --shell zsh|bash|fish)" ;;
    esac
    shift
  done

  # Preserve the project's Docker daemon exposure mode across syncs (the
  # compose file is regenerated wholesale) unless an explicit mode overrides it.
  # Read it from the CURRENT compose before apply_template overwrites the file.
  if [ -z "$docker" ]; then
    docker="$(read_compose_docker_mode)"
    case "$docker" in
      none|ro|rw) ;;
      invalid) err "existing Docker proxy toggles are inconsistent; resetting them to the secure 'none' mode"; docker="$DEFAULT_DOCKER" ;;
      *) docker="$DEFAULT_DOCKER" ;;
    esac
  fi

  # The repository-encoded mode is not authority by itself. Releases before
  # host-side consent existed also exposed Docker object reads in every project,
  # even when the user never asked for them. Reset any unconsented inherited
  # mode to `none` instead of reproducing it and making the next startup stop
  # for approval; an explicit flag below records fresh consent.
  if [ "$docker_explicit" = "0" ]; then
    case "$docker" in
      ro)
        if ! docker_consent_matches ro; then
          err "existing Docker read access has no matching host consent; resetting to 'none' (re-enable with 'aic sync --docker-read')"
          docker="none"
        fi
        ;;
      rw)
        if ! docker_consent_matches rw; then
          err "existing Docker read-write access has no matching host consent; resetting to 'none' (re-enable with 'aic sync --docker')"
          docker="none"
        fi
        ;;
    esac
  fi

  # Auto-detect: presence of .devcontainer/Dockerfile means the project was
  # initialized with --build; otherwise it's the pull-mode 2-file layout.
  if [ -z "$mode" ]; then
    if [ -f .devcontainer/Dockerfile ]; then
      mode="build"
    else
      mode="pull"
    fi
  fi

  # Preserve the existing tool selection across syncs unless overridden with
  # --with. Projects created before AIC_TOOLS existed fall back to all tools.
  if [ -z "$tools" ]; then
    tools="$(read_aic_tools)"
    [ -n "$tools" ] || tools="claude-code,codex,opencode"
  fi
  tools="$(validate_tools "$tools")"

  # Same pattern for shell. Projects created before AIC_SHELL existed get
  # the default (zsh), matching their pre-flag behavior.
  if [ -z "$shell" ]; then
    shell="$(read_aic_shell)"
    [ -n "$shell" ] || shell="$DEFAULT_SHELL"
  fi
  shell="$(validate_shell "$shell")"

  resolve_docker_socket >/dev/null || die "cannot sync aicontainer with the selected Docker context"
  apply_template "$mode" "$TEMPLATE_DIR" ".devcontainer" "$docker"
  patch_devcontainer_json ".devcontainer/devcontainer.json" "$tools" "$shell"
  # None is also a revocation: clear stale outside-repo read/write consent even
  # when a plain sync repaired malformed toggles back to the secure default.
  if [ "$docker_explicit" != "0" ] || [ "$docker" = "none" ]; then
    set_docker_consent "$docker"
  fi
  # A legacy project-name migration also changes the implicit per-project
  # sessions volume. Copy it while Docker is available; otherwise first up /
  # VS Code initialize performs the same zero-data-loss migration.
  if [ "$was_legacy" = "1" ]; then
    migrate_legacy_session_volume defer
  fi
  echo "aic: synced $mode-mode template → .devcontainer/ (tools: $tools, shell: $shell, docker: $docker)"
  case "$docker" in
    ro)
      echo "aic: Docker daemon READ access encoded — host Docker APIs may expose container metadata, logs, and files."
      docker_consent_matches ro || err "Docker read mode needs explicit host consent: re-run 'aic sync --docker-read'"
      ;;
    rw)
      echo "aic: Docker daemon READ-WRITE access encoded — the agent can create/build containers on the host daemon."
      docker_consent_matches rw || err "Docker write mode needs explicit host consent: re-run 'aic sync --docker'"
      ;;
  esac
  echo "aic: review with 'git diff -- .devcontainer/', then 'aic rebuild'"
  echo "aic: project-owned files (Dockerfile.project, firewall-allowlist, chown-paths, post-create.project.sh, docker-compose.override.yml, vscode-extensions, vscode-settings.json) are untouched"
  if [ -f .devcontainer/docker-compose.override.yml ]; then
    echo "aic: wired docker-compose.override.yml into dockerComposeFile"
  fi
  if [ -f .devcontainer/vscode-extensions ]; then
    local extcount; extcount="$(grep -cvE '^[[:space:]]*(#|$)' .devcontainer/vscode-extensions 2>/dev/null)" || extcount=0
    echo "aic: merged vscode-extensions ($extcount listed) into customizations.vscode.extensions"
  fi
  if [ -f .devcontainer/vscode-settings.json ]; then
    echo "aic: merged vscode-settings.json into customizations.vscode.settings"
  fi
  check_dockerfile_project_base "$(read_aic_version)" "$bump_base"
}

# Best-effort detection of whether the opt-in outbound firewall is currently
# active inside the running container. Echoes on|off|unknown and never fails.
# The firewall is enable-only, never auto-applied, and does not survive
# container recreation, so "off"/"unknown" is the safe (network-open) default.
# `sudo aic-firewall status` is one of the three scoped-sudo scripts, so this
# read is allowed; when enabled the OUTPUT chain shows `policy DROP`.
firewall_live_state () {
  local project template cid devcontainer out
  project="$(project_name)"
  template="$(trusted_compose_template)"
  cid="$(docker compose -p "$project" -f "$template" ps -q devcontainer 2>/dev/null)" || { echo unknown; return; }
  [ -n "$cid" ] || { echo unknown; return; }
  [ "$(docker inspect -f '{{.State.Running}}' "$cid" 2>/dev/null)" = "true" ] || { echo unknown; return; }
  devcontainer="$(resolve_devcontainer 2>/dev/null)" || { echo unknown; return; }
  out="$("$devcontainer" exec --workspace-folder . sudo aic-firewall status 2>/dev/null)" || { echo unknown; return; }
  if grep -q 'policy DROP' <<<"$out"; then echo on; else echo off; fi
}

# Scan project-owned, sync-preserved devcontainer files that can hand the
# container extra privilege or host access, BEFORE the stack comes up. These
# ride along inside an untrusted repo and are honored on `aic up`: a
# docker-compose.override.yml is auto-wired into dockerComposeFile (so its
# mounts/caps/namespaces apply), and a Dockerfile.project's FROM is what an
# override `build:` actually builds on. The aic-managed files can't express
# these (they're regenerated), so this scan reads only the project-owned ones.
#
# mode=gate (aic up / rebuild): print findings; on a TTY, prompt and abort on
# anything but yes. Non-interactive callers can't be blocked (automation), so
# they get the loud warning and proceed. mode=warn (check-drift / VS Code
# initializeCommand): print only, never prompt. Silence with AIC_NO_OVERRIDE_SCAN=1.
scan_project_overrides () {
  local mode="${1:-gate}"
  [ -n "${AIC_NO_OVERRIDE_SCAN:-}" ] && return 0
  local ov=".devcontainer/docker-compose.override.yml"
  local df=".devcontainer/Dockerfile.project"
  local findings=()

  if [ -f "$ov" ]; then
    if grep -qE '^[[:space:]]*privileged:[[:space:]]*(true|yes)([[:space:]]|$)' "$ov"; then
      findings+=("override: privileged: true — full host device access")
    fi
    if grep -qE '^[[:space:]]*cap_add:' "$ov"; then
      findings+=("override: cap_add — adds Linux capabilities (e.g. SYS_ADMIN)")
    fi
    if grep -qE '^[[:space:]]*(network_mode|pid|ipc|userns_mode):[[:space:]]*["'"'"']?host' "$ov"; then
      findings+=("override: shares a host namespace (network/pid/ipc/userns: host)")
    fi
    if grep -qE '^[[:space:]]*security_opt:' "$ov"; then
      findings+=("override: security_opt — may disable seccomp/apparmor")
    fi
    if grep -qE '/(var/)?run/docker\.sock' "$ov"; then
      findings+=("override: mounts the Docker socket — full host daemon control")
    fi
    if grep -qE '^[[:space:]]*-[[:space:]]*"?/(:|etc|root|home|var|usr|boot|sys|proc)([/:]|$)' "$ov" \
       || grep -qE '^[[:space:]]*source:[[:space:]]*"?/(etc|root|home|var|usr|boot|sys|proc)?([/:]|$)' "$ov"; then
      findings+=("override: binds a sensitive host path into the container")
    fi
    if grep -qE '^[[:space:]]*(POST|BUILD):[[:space:]]*1[[:space:]]*$' "$ov"; then
      findings+=("override: re-enables socket-proxy POST/BUILD — host container control (prefer 'aic sync --docker')")
    fi
    if grep -qE '^[[:space:]]*devices:' "$ov"; then
      findings+=("override: devices — maps host devices into the container")
    fi
  fi

  if [ -f "$df" ]; then
    if grep -qE '^[[:space:]]*FROM[[:space:]]' "$df" \
       && ! grep -qE '^[[:space:]]*FROM[[:space:]]+(ghcr\.io/stefanoginella/aicontainer|aicontainer-base)([:@[:space:]]|$)' "$df"; then
      findings+=("Dockerfile.project: FROM is not the aicontainer base — sandbox hardening may be absent")
    fi
  fi

  [ "${#findings[@]}" -eq 0 ] && return 0

  local y r rst
  if [ -t 2 ]; then y=$'\033[33m'; r=$'\033[31m'; rst=$'\033[0m'; else y=""; r=""; rst=""; fi
  printf '%saic: project-owned devcontainer files request extra host access:%s\n' "$r" "$rst" >&2
  local f
  for f in "${findings[@]}"; do printf '  %s!%s %s\n' "$y" "$rst" "$f" >&2; done
  printf '%saic: these take effect when the container comes up. Review them if this repo is not fully trusted.%s\n' "$y" "$rst" >&2
  printf 'aic: (silence this scan with AIC_NO_OVERRIDE_SCAN=1)\n' >&2

  if [ "$mode" = "gate" ] && [ -t 0 ]; then
    local reply
    printf '%saic: bring the container up anyway? [y/N]%s ' "$y" "$rst" >&2
    IFS= read -r reply || reply=""
    case "$reply" in
      y|Y|yes|YES) return 0 ;;
      *) die "aborted — review the files above, or set AIC_NO_OVERRIDE_SCAN=1 to bypass." ;;
    esac
  fi
  return 0
}

# Resolve and validate every host-facing configuration layer before Docker is
# allowed to create containers. The raw grep scan above remains a useful early
# warning (including for an override that has not been synced/wired yet), but it
# is not a security boundary: YAML merging, interpolation, relative paths, and
# service replacement are judged from `docker compose config --format json`.

trust_state_dir () {
  printf '%s/aicontainer/trust\n' "${XDG_STATE_HOME:-$HOME/.local/state}"
}

trust_state_file () {
  printf '%s/%s.sha256\n' "$(trust_state_dir)" "$(expected_project_name)"
}

docker_consent_file () {
  printf '%s/aicontainer/docker-write/%s\n' "${XDG_STATE_HOME:-$HOME/.local/state}" "$(expected_project_name)"
}

set_docker_consent () {
  local mode="$1" file dir tmp
  file="$(docker_consent_file)"; dir="$(dirname "$file")"
  if [ "$mode" = "ro" ] || [ "$mode" = "rw" ]; then
    mkdir -p "$dir" || die "could not create Docker-consent state directory: $dir"
    chmod 700 "$dir" 2>/dev/null || true
    tmp="$(mktemp "$dir/.consent.XXXXXX")"
    printf '%s\n' "$mode" > "$tmp"
    chmod 600 "$tmp" 2>/dev/null || true
    mv -f "$tmp" "$file"
  else
    rm -f "$file"
  fi
}

docker_consent_matches () {
  local mode="$1" file value=""
  [ "$mode" = "ro" ] || [ "$mode" = "rw" ] || return 1
  file="$(docker_consent_file)"
  [ -f "$file" ] && [ ! -L "$file" ] || return 1
  IFS= read -r value < "$file" || return 1
  # Backward-compatible with the previous write-only consent marker.
  [ "$value" != "enabled" ] || value="rw"
  [ "$value" = "$mode" ]
}

hash_validation_inputs () {
  local final_json="$1"
  node -e '
    const crypto = require("crypto"), fs = require("fs"), path = require("path");
    const h = crypto.createHash("sha256");
    const resolved = process.argv[1];
    h.update("<resolved-compose>\0");
    if (fs.existsSync(resolved)) h.update(fs.readFileSync(resolved));
    h.update("\0<devcontainer-tree>\0");
    function walk(root, relative = "") {
      const full = relative ? path.join(root, relative) : root;
      const stat = fs.lstatSync(full);
      const kind = stat.isDirectory() ? "d" : stat.isFile() ? "f" : stat.isSymbolicLink() ? "l" : "o";
      h.update(`${kind}:${relative}:${stat.mode & 0o7777}\0`);
      if (kind === "f") h.update(fs.readFileSync(full));
      else if (kind === "l") h.update(fs.readlinkSync(full));
      h.update("\0");
      if (kind === "d") {
        for (const name of fs.readdirSync(full).sort()) walk(root, path.join(relative, name));
      }
    }
    if (fs.existsSync(".devcontainer")) walk(".devcontainer");
    process.stdout.write(h.digest("hex"));
  ' "$final_json"
}

store_project_trust () {
  local hash="$1" dir file tmp
  dir="$(trust_state_dir)"; file="$(trust_state_file)"
  mkdir -p "$dir" || die "could not create trust state directory: $dir"
  chmod 700 "$dir" 2>/dev/null || true
  tmp="$(mktemp "$dir/.trust.XXXXXX")"
  printf '%s\n' "$hash" > "$tmp"
  chmod 600 "$tmp" 2>/dev/null || true
  mv -f "$tmp" "$file"
}

project_trust_matches () {
  local hash="$1" file saved=""
  file="$(trust_state_file)"
  [ -f "$file" ] && [ ! -L "$file" ] || return 1
  IFS= read -r saved < "$file" || return 1
  [ "$saved" = "$hash" ]
}

# Append managed build-mode file provenance failures to $1. These artifacts are
# copied wholesale by aic and execute as root while the image is built; unlike
# project-owned Dockerfile.project, hand-editing them is unsupported.
validate_managed_build_files () {
  local out="$1" name
  for name in README.md .gitignore; do
    if [ ! -f "$TEMPLATE_DIR/$name" ] || ! cmp -s "$TEMPLATE_DIR/$name" ".devcontainer/$name"; then
      printf 'MANAGED\t.devcontainer/%s differs from the managed template; run aic sync\n' "$name" >> "$out"
    fi
  done
  [ -f .devcontainer/Dockerfile ] || return 0
  for name in Dockerfile post-create.py aic-firewall aic-chown-volumes aic-lock-gitconfig .zshrc; do
    if [ ! -f "$TEMPLATE_DIR/$name" ] || ! cmp -s "$TEMPLATE_DIR/$name" ".devcontainer/$name"; then
      printf 'MANAGED\t.devcontainer/%s differs from the managed build template; run aic sync\n' "$name" >> "$out"
    fi
  done
  if [ ! -d .devcontainer/hooks ] || ! diff -qr "$TEMPLATE_DIR/hooks" .devcontainer/hooks >/dev/null 2>&1; then
    printf 'MANAGED\t.devcontainer/hooks differs from the managed build template; run aic sync\n' >> "$out"
  fi
}

# Emit MANAGED<TAB>... for an untrustable managed-config violation and
# UNSAFE<TAB>... for an intentional host-boundary expansion that may be
# explicitly approved. Node is already a package prerequisite (>=18).
analyze_resolved_config () {
  local base_json="$1" expected_json="$2" final_json="$3" noenv_json="$4"
  local raw_base_json="$5" raw_final_json="$6" out="$7"
  local has_override=0
  [ -f .devcontainer/docker-compose.override.yml ] && has_override=1
  node - \
    .devcontainer/devcontainer.json "$TEMPLATE_DIR/devcontainer.json" \
    "$base_json" "$expected_json" "$final_json" "$noenv_json" \
    "$raw_base_json" "$raw_final_json" "$(pwd -P)" \
    "$(expected_project_name)" "$has_override" "$(runtime_user_id)" >> "$out" <<'NODE'
const fs = require('fs');
const path = require('path');

const [devFile, templateDevFile, baseFile, expectedFile, finalFile, noenvFile,
  rawBaseFile, rawFinalFile, rootArg, expectedName, hasOverrideRaw, runtimeUser] = process.argv.slice(2);
const root = fs.realpathSync(rootArg);
const hasOverride = hasOverrideRaw === '1';
// Findings include repository-controlled service names, paths, and values.
// Render terminal controls visibly so validation itself cannot spoof prompts,
// erase prior output, or plant clickable escape sequences on the host.
const safeDiagnostic = value => String(value).replace(
  /[\u0000-\u001f\u007f-\u009f\u202a-\u202e\u2066-\u2069]/g,
  char => `\\u${char.codePointAt(0).toString(16).padStart(4, '0')}`,
);
