const unsafe = msg => process.stdout.write(`UNSAFE\t${safeDiagnostic(msg)}\n`);
const volatile = msg => process.stdout.write(`VOLATILE\t${safeDiagnostic(msg)}\n`);

function parseJsonc(file) {
