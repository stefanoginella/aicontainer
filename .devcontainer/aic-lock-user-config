#!/usr/bin/python3 -I
"""Install trusted user configuration behind a root-owned directory boundary.

This helper is called through a scoped NOPASSWD sudoers entry. It installs a
FIXED table of targets; every staging and destination path is hardcoded here
and never taken from argv. The unprivileged post-create process writes the
staging files; this helper validates each one and, without following symlinks,
atomically creates the final root-owned file exactly once using
descriptor-relative APIs.

Targets fall into two classes:

  * Validated config (``gitconfig``). Parsed against a fixed key/value
    allowlist before install; REQUIRED, so its absence is an error. This is the
    former ``aic-lock-gitconfig`` behavior, unchanged.

  * Verbatim personal shell (``shell/rc.zsh``, ``shell/p10k.zsh``). Arbitrary
    zsh that cannot be meaningfully allowlisted, so it is installed WITHOUT
    content validation; OPTIONAL, installed only when its staging file exists.
    Safe despite the missing content check because:
      1. the bytes originate from the trusted human's own config (a project
         file a human placed under ``.devcontainer/`` or the host ``$HOME``),
         staged by trusted post-create *before* any agent session runs;
      2. ``root:root 0444`` plus create-once means an agent cannot tamper with
         the installed file afterward, preserving the "shell startup is
         root-managed" guarantee; and
      3. root only OWNS the file — its contents still execute as the
         unprivileged ``vscode`` user when sourced, so they grant no privilege
         the agent does not already have.
    See AGENTS.md, "personal config overlay".
"""

from __future__ import annotations

import os
import pwd
import stat
import subprocess
import sys
from pathlib import Path
from typing import Callable, NoReturn, Optional


MAX_FILE_BYTES = 1024 * 1024

# Keep this fixed-key contract aligned with post-create.py's GIT_SEED_KEYS and
# setup_gitconfig(). None of these seed keys execute commands, load paths, alter
# remotes/credentials, or register hooks. Command/path-bearing aic-owned keys
# are accepted separately only at their exact compiled-in values below.
SAFE_VALUE_KEYS = {
    "user.name",
    "user.email",
    "user.useconfigonly",
    "init.defaultbranch",
    "core.autocrlf",
    "core.safecrlf",
    "core.ignorecase",
    "core.precomposeunicode",
    "pull.rebase",
    "pull.ff",
    "push.default",
    "push.autosetupremote",
    "push.followtags",
    "fetch.prune",
    "fetch.prunetags",
    "rebase.autostash",
    "rebase.autosquash",
    "rebase.updaterefs",
    "branch.autosetupmerge",
    "branch.autosetuprebase",
    "diff.algorithm",
    "diff.colormoved",
    "merge.conflictstyle",
    "commit.gpgsign",
    "tag.gpgsign",
}

EXACT_VALUES = {
    "core.excludesfile": "/etc/aic/gitignore",
    "core.pager": "delta",
    "interactive.difffilter": "delta --color-only",
    "delta.navigate": "true",
    "delta.line-numbers": "true",
    "gpg.format": "ssh",
    "user.signingkey": "/home/vscode/.config/aic-auth/signing/id_ed25519",
    "gpg.ssh.allowedsignersfile": "/home/vscode/.config/aic-auth/signing/allowed_signers",
}

REQUIRED_LAST_VALUES = {
    "core.excludesfile": "/etc/aic/gitignore",
    "core.pager": "delta",
    "interactive.difffilter": "delta --color-only",
    "delta.navigate": "true",
    "delta.line-numbers": "true",
    "merge.conflictstyle": "diff3",
    "diff.colormoved": "default",
}


def fail(message: str) -> NoReturn:
    print(f"aic-lock-user-config: {message}", file=sys.stderr)
    raise SystemExit(1)


class Target:
    """One hardcoded (staging -> destination) install with an optional validator."""

    __slots__ = ("staging", "dest_dir", "dest_name", "required", "validator")

    def __init__(
        self,
        staging: Path,
        dest_dir: Path,
        dest_name: str,
        required: bool,
        validator: Optional[Callable[[int], None]],
    ) -> None:
        self.staging = staging
        self.dest_dir = dest_dir
        self.dest_name = dest_name
        self.required = required
        self.validator = validator


def exact_realpath(path: Path, description: str) -> None:
    try:
        resolved = str(path.resolve(strict=True))
    except (OSError, RuntimeError) as error:
        fail(f"cannot resolve {description} {path}: {error}")
    if resolved != str(path):
        fail(f"refusing symlinked {description}: {path}")


def open_validated_source(
    target: Target, vscode_uid: int
) -> Optional[tuple[int, os.stat_result]]:
    """Open a target's staging file with no-follow/inode checks.

    Returns ``None`` when an OPTIONAL target has no staging file (that source
    was simply not provided). A REQUIRED target's absence is fatal.
    """
    exact_realpath(target.staging.parent, "staging parent")
    try:
        before = target.staging.lstat()
    except FileNotFoundError:
        if target.required:
            fail(f"staging file is missing: {target.staging}")
        return None
    if not stat.S_ISREG(before.st_mode):
        fail(f"refusing symlink or non-regular staging file: {target.staging}")
    if before.st_uid != vscode_uid:
        fail(f"staging file is not owned by vscode: {target.staging}")
    if before.st_nlink != 1:
        fail(f"staging file must not be hard-linked: {target.staging}")
    if before.st_size > MAX_FILE_BYTES:
        fail(f"staging file exceeds {MAX_FILE_BYTES} bytes: {target.staging}")

    flags = os.O_RDONLY | getattr(os, "O_CLOEXEC", 0) | getattr(os, "O_NOFOLLOW", 0)
    try:
        fd = os.open(target.staging, flags)
    except OSError as error:
        fail(f"cannot safely open staging file {target.staging}: {error}")

    opened = os.fstat(fd)
    opened_path = os.path.realpath(f"/proc/self/fd/{fd}")
    if (
        not stat.S_ISREG(opened.st_mode)
        or opened.st_uid != vscode_uid
        or opened.st_nlink != 1
        or opened.st_size > MAX_FILE_BYTES
        or (before.st_dev, before.st_ino) != (opened.st_dev, opened.st_ino)
        or opened_path != str(target.staging)
    ):
        os.close(fd)
        fail(f"staging file changed or escaped its hardcoded path: {target.staging}")
    return fd, opened


def validate_gitconfig_contents(source_fd: int) -> None:
    """Reject config keys that could execute code or cross trust boundaries."""
    env = {
        "GIT_CONFIG_NOSYSTEM": "1",
        "GIT_CONFIG_GLOBAL": "/dev/null",
        "HOME": "/nonexistent",
        "LC_ALL": "C",
        "PATH": "/usr/bin:/bin",
    }
    try:
        result = subprocess.run(
            [
                "/usr/bin/git",
                "config",
                "--no-includes",
                "--file",
                f"/dev/fd/{source_fd}",
                "--null",
                "--list",
            ],
            check=True,
            capture_output=True,
            close_fds=True,
            env=env,
            pass_fds=(source_fd,),
            timeout=3,
        )
    except (OSError, subprocess.CalledProcessError, subprocess.TimeoutExpired) as error:
        fail(f"staging file is not a valid bounded Git config: {error}")

    values: dict[str, list[str]] = {}
    for raw_record in result.stdout.split(b"\0"):
        if not raw_record:
            continue
        raw_key, separator, raw_value = raw_record.partition(b"\n")
        if not separator:
            fail("Git config parser returned a malformed record")
        key = raw_key.decode("utf-8", "surrogateescape").lower()
        value = raw_value.decode("utf-8", "surrogateescape")
        if key not in SAFE_VALUE_KEYS and key not in EXACT_VALUES:
            fail(f"staging config contains forbidden key: {key}")
        if key in EXACT_VALUES and value != EXACT_VALUES[key]:
            fail(f"staging config contains forbidden value for: {key}")
        values.setdefault(key, []).append(value)

    for key, required in REQUIRED_LAST_VALUES.items():
        if not values.get(key) or values[key][-1] != required:
            fail(f"staging config is missing aic's required value for: {key}")


# The fixed install table. gitconfig keeps its allowlist validator and stays
# required; the personal shell files are optional and installed verbatim (see
# the module docstring for why the missing content check is safe). Staging
# paths MUST match post-create.py's GITCONFIG_STAGING / SHELL_RC_STAGING /
# P10K_STAGING; destination directories MUST already exist root-owned (created
# in template/Dockerfile).
TARGETS = (
    Target(
        Path("/home/vscode/.aic-gitconfig.staging"),
        Path("/etc/aic/user-config"),
        "gitconfig",
        required=True,
        validator=validate_gitconfig_contents,
    ),
    Target(
        Path("/home/vscode/.aic-shell-rc.staging"),
        Path("/etc/aic/user-config/shell"),
        "rc.zsh",
        required=False,
        validator=None,
    ),
    Target(
        Path("/home/vscode/.aic-p10k.staging"),
        Path("/etc/aic/user-config/shell"),
        "p10k.zsh",
        required=False,
        validator=None,
    ),
)


def validate_destination_directory(dest_dir: Path) -> int:
    exact_realpath(dest_dir, "destination directory")
    try:
        info = dest_dir.lstat()
    except FileNotFoundError:
        fail(f"destination directory is missing: {dest_dir}")
    if not stat.S_ISDIR(info.st_mode) or info.st_uid != 0 or info.st_gid != 0:
        fail(f"destination directory must be root-owned: {dest_dir}")
    if stat.S_IMODE(info.st_mode) & 0o022:
        fail(f"destination directory must not be group/world writable: {dest_dir}")

    flags = os.O_RDONLY | os.O_DIRECTORY | getattr(os, "O_CLOEXEC", 0) | getattr(os, "O_NOFOLLOW", 0)
    try:
        directory_fd = os.open(dest_dir, flags)
    except OSError as error:
        fail(f"cannot safely open destination directory {dest_dir}: {error}")
    opened = os.fstat(directory_fd)
    if (info.st_dev, info.st_ino) != (opened.st_dev, opened.st_ino):
        os.close(directory_fd)
        fail(f"destination directory changed while opening: {dest_dir}")
    return directory_fd


def copy_to_locked_destination(
    source_fd: int,
    source_opened: os.stat_result,
    directory_fd: int,
    dest_dir: Path,
    dest_name: str,
) -> None:
    dest_display = dest_dir / dest_name
    # Never overwrite an installed file. This makes subsequent sudo helper
    # invocations unable to replace the trusted post-create result with content
    # written later by an agent in the same container.
    try:
        os.stat(dest_name, dir_fd=directory_fd, follow_symlinks=False)
    except FileNotFoundError:
        pass
    else:
        fail(f"destination already exists; refusing to replace: {dest_display}")

    temp_name = f".{dest_name}.tmp.{os.getpid()}"
    flags = os.O_WRONLY | os.O_CREAT | os.O_EXCL | getattr(os, "O_CLOEXEC", 0) | getattr(os, "O_NOFOLLOW", 0)
    try:
        temp_fd = os.open(temp_name, flags, 0o400, dir_fd=directory_fd)
    except OSError as error:
        fail(f"cannot create destination staging file: {error}")

    linked = False
    try:
        os.lseek(source_fd, 0, os.SEEK_SET)
        copied = 0
        while True:
            chunk = os.read(source_fd, 64 * 1024)
            if not chunk:
                break
            copied += len(chunk)
            if copied > MAX_FILE_BYTES:
                fail(f"staging file grew beyond {MAX_FILE_BYTES} bytes")
            view = memoryview(chunk)
            while view:
                written = os.write(temp_fd, view)
                view = view[written:]

        source_after_read = os.fstat(source_fd)
        if (
            source_after_read.st_dev,
            source_after_read.st_ino,
            source_after_read.st_size,
            source_after_read.st_mtime_ns,
            source_after_read.st_ctime_ns,
        ) != (
            source_opened.st_dev,
            source_opened.st_ino,
            source_opened.st_size,
            source_opened.st_mtime_ns,
            source_opened.st_ctime_ns,
        ):
            fail(f"staging file changed while being copied: {dest_display}")

        os.fchown(temp_fd, 0, 0)
        os.fchmod(temp_fd, 0o444)
        os.fsync(temp_fd)
        locked = os.fstat(temp_fd)
        if locked.st_uid != 0 or locked.st_gid != 0 or stat.S_IMODE(locked.st_mode) != 0o444:
            fail("failed to enforce root:root 0444 on destination")

        # link() is an atomic no-replace promotion. A concurrent helper can
        # never overwrite a destination that the first invocation installed.
        os.link(
            temp_name,
            dest_name,
            src_dir_fd=directory_fd,
            dst_dir_fd=directory_fd,
            follow_symlinks=False,
        )
        linked = True
        os.unlink(temp_name, dir_fd=directory_fd)
        os.fsync(directory_fd)

        final = os.stat(dest_name, dir_fd=directory_fd, follow_symlinks=False)
        if (
            not stat.S_ISREG(final.st_mode)
            or final.st_uid != 0
            or final.st_gid != 0
            or stat.S_IMODE(final.st_mode) != 0o444
            or (final.st_dev, final.st_ino) != (locked.st_dev, locked.st_ino)
            or final.st_nlink != 1
        ):
            fail(f"installed destination failed owner/mode/inode checks: {dest_display}")
    except FileExistsError:
        fail(f"destination already exists; refusing to replace: {dest_display}")
    finally:
        os.close(temp_fd)
        if not linked:
            try:
                os.unlink(temp_name, dir_fd=directory_fd)
            except FileNotFoundError:
                pass


def install_target(target: Target, vscode_uid: int) -> None:
    opened = open_validated_source(target, vscode_uid)
    if opened is None:
        return
    source_fd, source_stat = opened
    try:
        if target.validator is not None:
            target.validator(source_fd)
        directory_fd = validate_destination_directory(target.dest_dir)
        try:
            copy_to_locked_destination(
                source_fd, source_stat, directory_fd, target.dest_dir, target.dest_name
            )
        finally:
            os.close(directory_fd)
    finally:
        os.close(source_fd)


def main() -> None:
    if os.geteuid() != 0:
        fail("must run via sudo")
    try:
        vscode_uid = pwd.getpwnam("vscode").pw_uid
    except KeyError:
        fail("vscode user does not exist")

    for target in TARGETS:
        install_target(target, vscode_uid)


if __name__ == "__main__":
    main()
