#!/usr/bin/env bash
# =============================================================================
# aic-lock-gitconfig — make ~/.gitconfig.local root-owned and read-only
# =============================================================================
# Called once at the end of post-create.py. The file is the container-local
# git config pointed at by GIT_CONFIG_GLOBAL. Without this lock, a compromised
# tool session could append `[credential] helper = !cat > /tmp/x` or
# `[core] sshCommand = ...` to capture tokens during in-container `gh` /
# `git push` flows.
# =============================================================================
set -euo pipefail

if [ "$(id -u)" -ne 0 ]; then
  echo "aic-lock-gitconfig: must run via sudo" >&2
  exit 1
fi

f=/home/vscode/.gitconfig.local
[ -f "$f" ] || { echo "aic-lock-gitconfig: $f not found" >&2; exit 1; }
chown root:root "$f"
chmod 0444 "$f"
