{
  "$schema": "https://raw.githubusercontent.com/devcontainers/spec/main/schemas/devContainer.schema.json",
  "name": "aicontainer",
  "dockerComposeFile": ["docker-compose.yml"],
  "service": "devcontainer",
  "workspaceFolder": "/workspace",
  "remoteUser": "vscode",
  "updateRemoteUserUID": true,
  "init": true,
  "overrideCommand": false,

  "customizations": {
    "vscode": {
      "extensions": [
        "anthropic.claude-code",
        "eamodio.gitlens",
        "openai.chatgpt",
        "sst-dev.opencode",
        "pflannery.vscode-versionlens",
        "BracketPairColorDLW.bracket-pair-color-dlw",
        "vincaslt.highlight-matching-tag",
        "yzhang.markdown-all-in-one"
        // aic:vscode-extensions — project-owned .devcontainer/vscode-extensions
        // is merged here by `aic sync` (one extension id per line).
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "zsh",
        "terminal.integrated.profiles.linux": {
          "zsh": { "path": "zsh" },
          "bash": { "path": "bash" },
          "fish": { "path": "fish" }
        },
        "terminal.integrated.fontFamily": "'MesloLGS NF', monospace",
        "terminal.integrated.sendKeybindingsToShell": true,
        "terminal.integrated.rightClickBehavior": "paste",
        // Prevent file:/// OSC 8 links from triggering "No application found"
        // in devcontainers (microsoft/vscode#211443). VS Code's built-in file
        // link detection still works for opening workspace files in the editor.
        "terminal.integrated.allowedLinkSchemes": ["http", "https", "mailto", "vscode", "vscode-insiders"],
        "files.trimTrailingWhitespace": true,
        "files.insertFinalNewline": true,
        "files.trimFinalNewlines": true,
        "claude-code.allowDangerouslySkipPermissions": true,
        "claude-code.terminalArgs": ["--dangerously-skip-permissions"]
        // aic:vscode-settings — project-owned .devcontainer/vscode-settings.json
        // (a JSON object) is merged here by `aic sync`.
      }
    }
  },

  "containerEnv": {
    "DEVCONTAINER": "true",
    "CLAUDE_CONFIG_DIR": "/home/vscode/.claude",
    "OPENCODE_DB": "/home/vscode/.claude-sessions/opencode/opencode.db",
    "SEMGREP_SETTINGS_FILE": "/home/vscode/.config/aic-auth/semgrep/settings.yml",
    "NPM_CONFIG_IGNORE_SCRIPTS": "true",
    "NPM_CONFIG_AUDIT": "true",
    "NPM_CONFIG_FUND": "false",
    "NPM_CONFIG_UPDATE_NOTIFIER": "false",
    "NPM_CONFIG_MIN_RELEASE_AGE": "1",
    "NPM_CONFIG_USERCONFIG": "/home/vscode/.config/npm/npmrc",
    "PYTHONDONTWRITEBYTECODE": "1",
    "PIP_DISABLE_PIP_VERSION_CHECK": "1",
    "GIT_CONFIG_GLOBAL": "/home/vscode/.gitconfig.local"
  },

  // Host-side bootstrap that must run before `docker compose up`.
  //   1. mkdir/touch the host paths bind-mounted RO into the container (mounts
  //      fail if the source doesn't exist).
  //   2. Create the global volumes (aic-auth-global, aic-shell-history). Both
  //      are declared `external: true` in docker-compose.yml so Compose neither
  //      auto-creates them nor stamps them with a per-project owner label
  //      (which would make every other project warn on `up`) — so this
  //      bootstrap must guarantee they exist.
  //   3. Ensure aic-auth-global contains every subpath referenced by
  //      docker-compose.yml. Docker only auto-initializes a named volume from
  //      the image's mountpoint on its very first mount; if a new subpath is
  //      added later (e.g. npm), existing users' volumes are already non-empty
  //      and the mount fails with "no such file or directory". busybox is tiny
  //      (~5MB) and pulled once.
  "initializeCommand": "mkdir -p \"$HOME/.claude/statusline\" \"$HOME/.codex\" \"$HOME/.config/opencode\" && touch \"$HOME/.claude/settings.json\" \"$HOME/.codex/config.toml\" \"$HOME/.config/opencode/opencode.json\" \"$HOME/.gitconfig\" \"$HOME/.zshrc.local\" \"$HOME/.p10k.zsh\" && docker volume create aic-auth-global >/dev/null && docker volume create aic-shell-history >/dev/null && docker run --rm -v aic-auth-global:/v busybox mkdir -p /v/claude /v/codex /v/opencode /v/gh /v/npm && { command -v aic >/dev/null 2>&1 && aic check-drift >/dev/null; true; }",

  "postCreateCommand": "uv run --no-project /opt/post-create.py"
}
